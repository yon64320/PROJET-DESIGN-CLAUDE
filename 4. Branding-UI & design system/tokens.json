{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Studio Kodo — Design Tokens v1 — Mid-century modern + luxe épuré",
  "$version": "1.1.0",

  "color": {
    "surface": {
      "primary": {
        "$type": "color",
        "$value": "oklch(97.5% 0.008 80)",
        "$description": "Main background — warm cream",
        "$extensions": {
          "role": "Primary page background",
          "usage_context": "Body, main content areas, hero sections",
          "do_not_use": "Overlays, elevated cards, dark-surfaced sections",
          "paired_with": ["color.text.primary", "color.border.subtle"],
          "fallback": "#FAF7F2"
        }
      },
      "secondary": {
        "$type": "color",
        "$value": "oklch(94.5% 0.012 80)",
        "$description": "Alternate section background — slightly warmer cream",
        "$extensions": {
          "role": "Alternating section backgrounds for visual rhythm",
          "usage_context": "Every other section on page, ghost button hover",
          "do_not_use": "Cards (use surface-elevated), text backgrounds",
          "paired_with": ["color.text.primary", "color.border.subtle"],
          "fallback": "#F2EDE5"
        }
      },
      "elevated": {
        "$type": "color",
        "$value": "oklch(100% 0 0)",
        "$description": "Elevated surfaces — cards, dropdowns",
        "$extensions": {
          "role": "Cards, modals, dropdowns, inputs",
          "usage_context": "Any surface that sits above primary/secondary backgrounds",
          "do_not_use": "Page backgrounds, full-width sections",
          "paired_with": ["shadow.card", "color.border.subtle"],
          "fallback": "#FFFFFF"
        }
      },
      "overlay": {
        "$type": "color",
        "$value": "oklch(15% 0.005 100 / 0.6)",
        "$description": "Overlay for modals and mobile menu",
        "$extensions": {
          "role": "Semi-transparent backdrop behind modals, mobile nav overlay",
          "usage_context": "Modal backdrops, menu overlays, image text overlays",
          "do_not_use": "Regular backgrounds, card surfaces",
          "paired_with": ["color.text.on-accent"],
          "fallback": "rgba(26,26,24,0.6)"
        }
      }
    },
    "text": {
      "primary": {
        "$type": "color",
        "$value": "oklch(15% 0.005 100)",
        "$description": "Primary text — warm charcoal (never pure black)",
        "$extensions": {
          "role": "Headings, body text, primary content",
          "usage_context": "H1–H4, paragraphs, nav items, card titles",
          "do_not_use": "Muted captions, placeholders",
          "paired_with": ["color.surface.primary", "color.surface.secondary"],
          "fallback": "#1A1A18"
        }
      },
      "secondary": {
        "$type": "color",
        "$value": "oklch(36% 0.008 100)",
        "$description": "Secondary text — medium warm gray",
        "$extensions": {
          "role": "Subtitles, descriptions, metadata, icon default color",
          "usage_context": "Subheadings, card descriptions, form labels, icon color",
          "do_not_use": "Headings, CTA text",
          "paired_with": ["color.surface.primary"],
          "fallback": "#4A4A46"
        }
      },
      "muted": {
        "$type": "color",
        "$value": "oklch(60% 0.008 100)",
        "$description": "Muted text — light warm gray",
        "$extensions": {
          "role": "Placeholder text, captions, copyright, timestamps",
          "usage_context": "Input placeholders, footer copyright, disabled labels",
          "do_not_use": "Body text, headings, interactive labels",
          "paired_with": ["color.surface.primary"],
          "fallback": "#8A8A84"
        }
      },
      "on-accent": {
        "$type": "color",
        "$value": "oklch(100% 0 0)",
        "$description": "Text on accent/CTA backgrounds — white",
        "$extensions": {
          "role": "Text and icons on accent-colored backgrounds",
          "usage_context": "Button primary text, badge text on dark bg, overlay text",
          "do_not_use": "On light backgrounds (use text-primary instead)",
          "paired_with": ["color.accent.action", "color.status.error", "color.status.success"],
          "fallback": "#FFFFFF"
        }
      }
    },
    "accent": {
      "action": {
        "$type": "color",
        "$value": "oklch(58% 0.1 175)",
        "$description": "Primary CTA and action color — deep teal",
        "$extensions": {
          "role": "Primary call-to-action backgrounds, active states, key interactive elements",
          "usage_context": "Primary buttons, active nav underline, focus rings, links, progress fill",
          "do_not_use": "Large background areas, decorative elements, body text",
          "paired_with": ["color.text.on-accent"],
          "fallback": "#008F82"
        }
      },
      "action-hover": {
        "$type": "color",
        "$value": "oklch(52% 0.1 175)",
        "$description": "CTA hover state — darker teal",
        "$extensions": {
          "role": "Hover and active state for primary actions",
          "usage_context": "Button hover, link hover, active press state",
          "do_not_use": "Default states, non-interactive elements",
          "paired_with": ["color.text.on-accent"],
          "fallback": "#007A6F"
        }
      },
      "warm": {
        "$type": "color",
        "$value": "oklch(72% 0.14 85)",
        "$description": "Warm accent — mustard/golden",
        "$extensions": {
          "role": "Secondary accent for warmth, decorative highlights, badge 'Projet concept'",
          "usage_context": "Badge backgrounds (at 15% opacity), decorative geometric shapes, warning status",
          "do_not_use": "Body text (contrast too low), CTA buttons, links",
          "paired_with": ["color.text.primary (large text only)"],
          "fallback": "#D4991A"
        }
      },
      "secondary": {
        "$type": "color",
        "$value": "oklch(58% 0.15 55)",
        "$description": "Secondary accent — burnt orange",
        "$extensions": {
          "role": "Tertiary decorative accent, case study differentiation",
          "usage_context": "Decorative geometric elements, case study category color, hover accents",
          "do_not_use": "CTA buttons, body text, form elements",
          "paired_with": ["color.surface.primary"],
          "fallback": "#C86218"
        }
      },
      "tertiary": {
        "$type": "color",
        "$value": "oklch(50% 0.09 110)",
        "$description": "Tertiary accent — olive green",
        "$extensions": {
          "role": "Subtle decorative accent, variety in geometric elements",
          "usage_context": "Decorative lines, geometric shapes, category tags",
          "do_not_use": "CTA, text, interactive elements",
          "paired_with": ["color.surface.primary"],
          "fallback": "#6E7228"
        }
      }
    },
    "border": {
      "subtle": {
        "$type": "color",
        "$value": "oklch(90% 0.01 80)",
        "$description": "Subtle border — light warm gray",
        "$extensions": {
          "role": "Light separators, input default borders, section dividers",
          "usage_context": "Input borders (default), card borders, accordion dividers, progress track",
          "do_not_use": "Active/focused states (use accent-action or border-strong)",
          "paired_with": ["color.surface.elevated"],
          "fallback": "#E5E0D8"
        }
      },
      "strong": {
        "$type": "color",
        "$value": "oklch(80% 0.015 80)",
        "$description": "Strong border — medium warm gray",
        "$extensions": {
          "role": "Visible separators, hover input borders, expanded accordion borders",
          "usage_context": "Input hover borders, expanded accordion bottom, footer separator",
          "do_not_use": "Default resting states",
          "paired_with": ["color.surface.primary"],
          "fallback": "#C8C2B8"
        }
      }
    },
    "status": {
      "success": {
        "$type": "color",
        "$value": "oklch(50% 0.1 155)",
        "$description": "Success state — forest green",
        "$extensions": {
          "role": "Success feedback, valid form fields, confirmation",
          "usage_context": "Input success border, success badge, confirmation message icon",
          "do_not_use": "Decorative elements, brand accents",
          "paired_with": ["color.text.on-accent (on solid bg)", "color.surface.primary (on light bg)"],
          "fallback": "#2D7A4F"
        }
      },
      "error": {
        "$type": "color",
        "$value": "oklch(48% 0.17 28)",
        "$description": "Error state — muted red",
        "$extensions": {
          "role": "Error feedback, invalid form fields, critical alerts",
          "usage_context": "Input error border, error message text+icon, error button variant",
          "do_not_use": "Decorative elements, brand accents",
          "paired_with": ["color.text.on-accent (on solid bg)"],
          "fallback": "#C4382A"
        }
      },
      "warning": {
        "$type": "color",
        "$value": "{color.accent.warm}",
        "$description": "Warning state — aliases accent-warm (mustard)"
      },
      "info": {
        "$type": "color",
        "$value": "{color.accent.action}",
        "$description": "Info state — aliases accent-action (teal)"
      }
    }
  },

  "typography": {
    "font-family": {
      "heading": {
        "$type": "fontFamily",
        "$value": ["Jost", "system-ui", "sans-serif"],
        "$description": "Geometric sans-serif for headings — mid-century character"
      },
      "body": {
        "$type": "fontFamily",
        "$value": ["Lora", "Georgia", "serif"],
        "$description": "Elegant serif for body text — readability + warmth"
      },
      "mono": {
        "$type": "fontFamily",
        "$value": ["JetBrains Mono", "Consolas", "monospace"],
        "$description": "Monospace for technical content if needed"
      }
    },
    "font-size": {
      "heading-5xl": {
        "$type": "dimension",
        "$value": "4.5rem",
        "$description": "72px — H1 Hero only",
        "$extensions": { "mobile": "2.5rem" }
      },
      "heading-4xl": {
        "$type": "dimension",
        "$value": "3.5rem",
        "$description": "56px — H1 interior pages",
        "$extensions": { "mobile": "2rem" }
      },
      "heading-3xl": {
        "$type": "dimension",
        "$value": "2.5rem",
        "$description": "40px — H2 major sections",
        "$extensions": { "mobile": "1.75rem" }
      },
      "heading-2xl": {
        "$type": "dimension",
        "$value": "2rem",
        "$description": "32px — H2 secondary sections",
        "$extensions": { "mobile": "1.5rem" }
      },
      "heading-xl": {
        "$type": "dimension",
        "$value": "1.5rem",
        "$description": "24px — H3",
        "$extensions": { "mobile": "1.25rem" }
      },
      "heading-lg": {
        "$type": "dimension",
        "$value": "1.25rem",
        "$description": "20px — H4, card titles",
        "$extensions": { "mobile": "1.125rem" }
      },
      "body-lg": {
        "$type": "dimension",
        "$value": "1.25rem",
        "$description": "20px — Lead paragraphs",
        "$extensions": { "mobile": "1.125rem" }
      },
      "body-md": {
        "$type": "dimension",
        "$value": "1.0625rem",
        "$description": "17px — Primary body text",
        "$extensions": { "mobile": "1rem" }
      },
      "body-sm": {
        "$type": "dimension",
        "$value": "0.9375rem",
        "$description": "15px — Captions, metadata",
        "$extensions": { "mobile": "0.875rem" }
      },
      "body-xs": {
        "$type": "dimension",
        "$value": "0.8125rem",
        "$description": "13px — Labels, microcopy",
        "$extensions": { "mobile": "0.75rem" }
      }
    },
    "font-weight": {
      "regular": { "$type": "number", "$value": 400 },
      "medium": { "$type": "number", "$value": 500 },
      "semibold": { "$type": "number", "$value": 600 },
      "bold": { "$type": "number", "$value": 700 }
    },
    "line-height": {
      "tight": { "$type": "number", "$value": 1.05, "$description": "Display headings (5xl)" },
      "heading": { "$type": "number", "$value": 1.15, "$description": "Standard headings" },
      "normal": { "$type": "number", "$value": 1.5, "$description": "UI text, labels" },
      "relaxed": { "$type": "number", "$value": 1.65, "$description": "Body text for reading" }
    },
    "letter-spacing": {
      "display": { "$type": "dimension", "$value": "-0.02em", "$description": "5xl–3xl headings" },
      "heading": { "$type": "dimension", "$value": "-0.01em", "$description": "2xl–lg headings" },
      "normal": { "$type": "dimension", "$value": "0em", "$description": "Body text" },
      "wide": { "$type": "dimension", "$value": "0.08em", "$description": "Uppercase labels, badges" }
    }
  },

  "spacing": {
    "section": {
      "$type": "dimension",
      "$value": "120px",
      "$description": "Between major page sections",
      "$extensions": { "mobile": "80px" }
    },
    "section-sm": {
      "$type": "dimension",
      "$value": "80px",
      "$description": "Between sub-sections",
      "$extensions": { "mobile": "56px" }
    },
    "component": {
      "$type": "dimension",
      "$value": "40px",
      "$description": "Between components within a section",
      "$extensions": { "mobile": "32px" }
    },
    "component-sm": {
      "$type": "dimension",
      "$value": "24px",
      "$description": "Between sibling elements within a component",
      "$extensions": { "mobile": "20px" }
    },
    "element": {
      "$type": "dimension",
      "$value": "16px",
      "$description": "Internal component padding (cards, buttons)"
    },
    "element-sm": {
      "$type": "dimension",
      "$value": "12px",
      "$description": "Compact spacing (badges, tags)"
    },
    "inline": {
      "$type": "dimension",
      "$value": "8px",
      "$description": "Between inline elements (icon + text)"
    },
    "inline-sm": {
      "$type": "dimension",
      "$value": "4px",
      "$description": "Micro spacing"
    }
  },

  "radius": {
    "none": { "$type": "dimension", "$value": "0px" },
    "sm": { "$type": "dimension", "$value": "4px", "$description": "Badges, tags, inputs" },
    "md": { "$type": "dimension", "$value": "8px", "$description": "Buttons, cards, modals" },
    "lg": { "$type": "dimension", "$value": "16px", "$description": "Featured cards, large containers" },
    "full": { "$type": "dimension", "$value": "9999px", "$description": "Avatars, pills, toggles" }
  },

  "shadow": {
    "subtle": {
      "$type": "shadow",
      "$value": { "offsetX": "0px", "offsetY": "1px", "blur": "3px", "spread": "0px", "color": "oklch(15% 0.005 100 / 0.06)" },
      "$description": "Subtle hover, light separation"
    },
    "card": {
      "$type": "shadow",
      "$value": { "offsetX": "0px", "offsetY": "4px", "blur": "12px", "spread": "0px", "color": "oklch(15% 0.005 100 / 0.08)" },
      "$description": "Card resting state"
    },
    "elevated": {
      "$type": "shadow",
      "$value": { "offsetX": "0px", "offsetY": "8px", "blur": "24px", "spread": "0px", "color": "oklch(15% 0.005 100 / 0.12)" },
      "$description": "Card hover, dropdowns"
    },
    "overlay": {
      "$type": "shadow",
      "$value": { "offsetX": "0px", "offsetY": "16px", "blur": "48px", "spread": "0px", "color": "oklch(15% 0.005 100 / 0.16)" },
      "$description": "Modals, mobile menu"
    }
  },

  "easing": {
    "entrance": {
      "$type": "cubicBezier",
      "$value": [0, 0, 0.2, 1],
      "$description": "Elements appearing — scroll reveal, page load",
      "$extensions": { "gsap": "power2.out" }
    },
    "entrance-dramatic": {
      "$type": "cubicBezier",
      "$value": [0, 0, 0.1, 1],
      "$description": "Word-split, signature entrances — Tier 2+",
      "$extensions": { "gsap": "power3.out" }
    },
    "exit": {
      "$type": "cubicBezier",
      "$value": [0.4, 0, 1, 1],
      "$description": "Elements disappearing — modal close, dismiss",
      "$extensions": { "gsap": "power2.in" }
    },
    "state-change": {
      "$type": "cubicBezier",
      "$value": [0.4, 0, 0.2, 1],
      "$description": "Hover, focus, toggle, tab switch",
      "$extensions": { "gsap": "power2.inOut" }
    },
    "bounce": {
      "$type": "cubicBezier",
      "$value": [0.34, 1.56, 0.64, 1],
      "$description": "Selection bounce, playful micro-interactions — use sparingly",
      "$extensions": { "gsap": "back.out(1.7)" }
    },
    "elastic-return": {
      "$type": "cubicBezier",
      "$value": [0.25, 1, 0.5, 1],
      "$description": "Magnetic button return — Tier 2+ only",
      "$extensions": { "gsap": "elastic.out(1, 0.4)", "note": "CSS approximation only — use GSAP string for precision" }
    },
    "scrub": {
      "$type": "cubicBezier",
      "$value": [0, 0, 1, 1],
      "$description": "Parallax, scroll storyboard — linear",
      "$extensions": { "gsap": "none" }
    }
  },

  "animation": {
    "$description": "Animation duration tokens — Tier 3 (GSAP + ScrollTrigger + Lenis + Spline 3D)",
    "duration": {
      "micro": {
        "$type": "duration",
        "$value": "50ms",
        "$description": "Button press, instant feedback"
      },
      "fast": {
        "$type": "duration",
        "$value": "150ms",
        "$description": "Hover, focus, state transitions"
      },
      "medium": {
        "$type": "duration",
        "$value": "300ms",
        "$description": "Card hover depth, accordion, magnetic approach"
      },
      "entrance": {
        "$type": "duration",
        "$value": "500ms",
        "$description": "ScrollTrigger reveal, content entrance"
      },
      "signature": {
        "$type": "duration",
        "$value": "800ms",
        "$description": "Word-split entrance, signature animations"
      },
      "counter": {
        "$type": "duration",
        "$value": "1500ms",
        "$description": "Counter animation on metrics"
      },
      "magnetic-return": {
        "$type": "duration",
        "$value": "500ms",
        "$description": "Magnetic button elastic return"
      }
    },
    "stagger": {
      "tight": {
        "$type": "duration",
        "$value": "60ms",
        "$description": "Word-split words"
      },
      "normal": {
        "$type": "duration",
        "$value": "100ms",
        "$description": "List items, CTA group"
      },
      "relaxed": {
        "$type": "duration",
        "$value": "150ms",
        "$description": "Cards, large blocks"
      },
      "wide": {
        "$type": "duration",
        "$value": "200ms",
        "$description": "Service cards, major sections"
      }
    }
  },

  "grid": {
    "columns": {
      "sm": { "$type": "number", "$value": 4, "$description": "< 640px" },
      "md": { "$type": "number", "$value": 8, "$description": "640–1023px" },
      "lg": { "$type": "number", "$value": 12, "$description": "≥ 1024px" }
    },
    "gutter": {
      "sm": { "$type": "dimension", "$value": "16px" },
      "md": { "$type": "dimension", "$value": "24px" },
      "lg": { "$type": "dimension", "$value": "32px" }
    },
    "margin": {
      "sm": { "$type": "dimension", "$value": "20px" },
      "md": { "$type": "dimension", "$value": "32px" },
      "lg": { "$type": "dimension", "$value": "48px" },
      "xl": { "$type": "dimension", "$value": "80px" }
    },
    "max-width": {
      "$type": "dimension",
      "$value": "1440px",
      "$description": "Content max-width — centered beyond this"
    }
  },

  "theme": {
    "dark": {
      "$description": "Dark mode overrides — warm charcoal surfaces, lifted accents",
      "color": {
        "surface": {
          "primary": { "$type": "color", "$value": "oklch(15% 0.005 100)", "$extensions": { "fallback": "#1A1A18" } },
          "secondary": { "$type": "color", "$value": "oklch(18% 0.005 100)", "$extensions": { "fallback": "#242422" } },
          "elevated": { "$type": "color", "$value": "oklch(22% 0.005 100)", "$extensions": { "fallback": "#2E2E2C" } },
          "overlay": { "$type": "color", "$value": "oklch(0% 0 0 / 0.7)", "$extensions": { "fallback": "rgba(0,0,0,0.7)" } }
        },
        "text": {
          "primary": { "$type": "color", "$value": "oklch(94.5% 0.012 80)", "$extensions": { "fallback": "#F2EDE5" } },
          "secondary": { "$type": "color", "$value": "oklch(74% 0.015 80)", "$extensions": { "fallback": "#B8B2A8" } },
          "muted": { "$type": "color", "$value": "oklch(52% 0.01 80)", "$extensions": { "fallback": "#7A7670" } },
          "on-accent": { "$type": "color", "$value": "oklch(100% 0 0)", "$extensions": { "fallback": "#FFFFFF" } }
        },
        "accent": {
          "action": { "$type": "color", "$value": "oklch(68% 0.1 175)", "$extensions": { "fallback": "#00B5A5" } },
          "action-hover": { "$type": "color", "$value": "oklch(75% 0.1 175)", "$extensions": { "fallback": "#00CDB8" } },
          "warm": { "$type": "color", "$value": "oklch(78% 0.14 85)", "$extensions": { "fallback": "#E8B830" } },
          "secondary": { "$type": "color", "$value": "oklch(63% 0.15 55)", "$extensions": { "fallback": "#E07828" } },
          "tertiary": { "$type": "color", "$value": "oklch(58% 0.09 110)", "$extensions": { "fallback": "#8A8E38" } }
        },
        "border": {
          "subtle": { "$type": "color", "$value": "oklch(24% 0.005 100)", "$extensions": { "fallback": "#333330" } },
          "strong": { "$type": "color", "$value": "oklch(36% 0.008 100)", "$extensions": { "fallback": "#4A4A46" } }
        },
        "status": {
          "success": { "$type": "color", "$value": "oklch(60% 0.1 155)", "$extensions": { "fallback": "#3DA566" } },
          "error": { "$type": "color", "$value": "oklch(56% 0.17 28)", "$extensions": { "fallback": "#E04E40" } },
          "warning": { "$type": "color", "$value": "{theme.dark.color.accent.warm}" },
          "info": { "$type": "color", "$value": "{theme.dark.color.accent.action}" }
        }
      },
      "shadow": {
        "subtle": { "$type": "shadow", "$value": { "offsetX": "0px", "offsetY": "1px", "blur": "3px", "spread": "0px", "color": "oklch(0% 0 0 / 0.2)" } },
        "card": { "$type": "shadow", "$value": { "offsetX": "0px", "offsetY": "4px", "blur": "12px", "spread": "0px", "color": "oklch(0% 0 0 / 0.3)" } },
        "elevated": { "$type": "shadow", "$value": { "offsetX": "0px", "offsetY": "8px", "blur": "24px", "spread": "0px", "color": "oklch(0% 0 0 / 0.4)" } },
        "overlay": { "$type": "shadow", "$value": { "offsetX": "0px", "offsetY": "16px", "blur": "48px", "spread": "0px", "color": "oklch(0% 0 0 / 0.5)" } }
      }
    }
  }
}
