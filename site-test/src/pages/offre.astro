---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionWrapper from '../components/SectionWrapper.astro';
import Button from '../components/Button.astro';
import Card from '../components/Card.astro';
import AccordionFAQ from '../components/AccordionFAQ.astro';
import ProcessStep from '../components/ProcessStep.astro';
import { SITE } from '../config';

import processData from '../content/process.json';

const faqOffre = [
  {
    id: "dependance-systeme",
    question: "Je ne veux pas dépendre d'un système compliqué après la livraison.",
    answer: "Les zones éditables sont identifiées dès la phase de cadrage — pas en fin de projet. Tout ce qui est destiné à évoluer (témoignages, cas clients, FAQ, textes de section) est éditable sans compétence technique. Ce qui est fixe est documenté dans le guide d'édition — et cette fixité a une raison précise.",
  },
  {
    id: "modifier-site",
    question: "Qui pourra modifier le site après la livraison ?",
    answer: "On livre un guide d'édition avec chaque projet. Les zones éditables sont clairement identifiées et documentées. Vous n'avez pas besoin de nous pour changer un témoignage, une photo, un texte de section ou une entrée FAQ. Pour les modifications structurelles, on peut intervenir dans le cadre de l'accompagnement post-livraison.",
  },
  {
    id: "comprendre-metier",
    question: "Est-ce que vous comprenez vraiment notre métier ?",
    answer: "La phase de cadrage est conçue pour ça — et elle précède toute maquette. On part de vos objectifs commerciaux, de vos clients réels, de vos preuves disponibles. On ne part pas d'un template sectoriel. Si à l'issue du cadrage on ne comprend pas votre marché et vos enjeux, on vous le dit.",
  },
  {
    id: "pas-le-temps",
    question: "On n'a vraiment pas le temps de gérer un projet en ce moment.",
    answer: "Notre process demande au total 3h30 de votre temps sur 4 à 6 semaines. Réparti en 4 sessions courtes — jamais plus de 1h d'un coup. Entre ces sessions, vous avez des livrables à valider, pas à produire. Si ce timing n'est pas réaliste maintenant, on peut planifier sur une fenêtre différente.",
  },
  {
    id: "prix-projet",
    question: "Comment vous calculez le prix d'un projet ?",
    answer: "Chaque projet est évalué selon sa complexité : nombre de pages, automatisations souhaitées, intégrations nécessaires, niveau de design. On ne donne pas de devis en aveugle. Lors de l'appel découverte (30 min), on peut vous donner une fourchette précise et les variables qui l'impactent.",
  },
  {
    id: "automatisation-utile",
    question: "L'automatisation, c'est vraiment utile pour une PME comme nous ?",
    answer: "Ça dépend de ce que vous faites manuellement aujourd'hui. Si vous passez plus d'une heure par semaine à qualifier des demandes, répondre aux mêmes questions, ou trier des données — la réponse est très probablement oui. On identifie ces cas ensemble lors du cadrage, avant de proposer quoi que ce soit.",
  },
];

const inclus = [
  "Audit et cadrage stratégique initial",
  "Architecture UX et spécifications de conversion",
  "Design sur mesure (non basé sur des templates)",
  "Intégration et déploiement",
  "Configuration du tracking (GA4 minimum)",
  "Optimisation conversion post-lancement (bilan J+30)",
  "Automatisations simples à intermédiaires selon besoins identifiés",
  "Intégration IA sur cas d'usage validés lors du cadrage",
  "Guide d'édition des zones éditables",
];

const exclus = [
  "Développement d'application SaaS ou logiciel métier complexe",
  "Stratégie marketing 360° ou gestion de campagnes (SEA, Social Ads)",
  "Maintenance illimitée ou support 24/7 post-livraison",
  "R&D IA ou développement de modèles spécifiques",
  "Production de contenu rédactionnel autre que le copy du site",
  "Shooting photo ou production vidéo",
];
---

<BaseLayout
  title="Notre offre — Site web, automatisation et IA pour PME"
  description="Site orienté conversion, automatisation des tâches répétitives et intégration IA concrète. Périmètre clair, process documenté, interlocuteur unique."
>

  <!-- HERO OFFRE -->
  <SectionWrapper size="lg" bg="default">
    <div class="hero-offre reveal">
      <h1>Un accompagnement complet — et un périmètre qui ne changera pas en cours de route.</h1>
      <p class="hero-sub">Pas de prestataire flou. Voici ce qu'on fait, ce qu'on ne fait pas, et comment on le fait.</p>
      <div class="hero-cta-row">
        <Button href={SITE.calendlyUrl} variant="primary" target="_blank" rel="noopener noreferrer">
          Réserver mon appel découverte
        </Button>
        <span class="cta-micro">30 min — sans engagement</span>
      </div>
    </div>
  </SectionWrapper>

  <!-- LES 3 PILIERS -->
  <SectionWrapper bg="surface" size="md">
    <div class="section-header reveal">
      <h2>Ce que couvre notre accompagnement</h2>
    </div>

    <div class="pillar-detail reveal">
      <h3>Site orienté conversion</h3>
      <p>Ce n'est pas un template mis à vos couleurs. C'est une structure conçue spécifiquement pour vos objectifs, votre audience et vos messages prioritaires.</p>
      <ul class="detail-list" role="list">
        {[
          "Audit et cadrage stratégique (objectifs, audience, messages)",
          "Architecture UX et spécifications de conversion par page",
          "Design sur mesure non basé sur des templates",
          "Intégration, déploiement, configuration du tracking",
          "Optimisation conversion post-lancement (premier bilan à J+30)",
          "Guide d'édition des zones éditables (inclus)",
        ].map((item) => <li>{item}</li>)}
      </ul>
      <p class="not-this"><strong>Ce que ce n'est pas :</strong> un site "beau" sans objectif mesurable. Si un élément de design ne sert pas la conversion ou la crédibilité, il n'est pas là.</p>
    </div>

    <hr class="section-divider" />

    <div class="pillar-detail reveal">
      <h3>Automatisation des tâches répétitives</h3>
      <p>On automatise ce que vous faites déjà — pas ce qu'on imagine que vous devriez faire.</p>
      <ul class="detail-list" role="list">
        {[
          "Identification des tâches répétitives manuelles avec potentiel d'automatisation",
          "Mise en place de formulaires intelligents (qualification intégrée)",
          "Automatisation des réponses aux demandes récurrentes",
          "Connexion et traitement de données entre vos outils",
        ].map((item) => <li>{item}</li>)}
      </ul>
      <p class="not-this"><strong>Ce que ce n'est pas :</strong> des automatisations génériques "pour gagner du temps en général". Chaque automatisation proposée répond à une tâche existante identifiée lors du cadrage.</p>
    </div>

    <hr class="section-divider" />

    <div class="pillar-detail reveal">
      <h3>Intégration IA sur des cas concrets</h3>
      <p>Le critère d'une intégration IA dans un projet : résoudre un problème que vous avez aujourd'hui, avec un gain mesurable.</p>
      <ul class="detail-list" role="list">
        {[
          "Qualification automatique des leads entrants (triage par critères définis)",
          "Assistance à la réponse client (FAQ automatisée, premier niveau de traitement)",
          "Analyse et tri de données entrantes",
        ].map((item) => <li>{item}</li>)}
      </ul>
      <p class="not-this"><strong>Ce qu'on ne fait pas :</strong> intégration IA "pour impressionner". Si ça ne résout pas un problème réel avec un ROI identifiable, on ne le propose pas.</p>
    </div>
  </SectionWrapper>

  <!-- INCLUS / EXCLU -->
  <SectionWrapper bg="muted" size="md">
    <div class="section-header reveal">
      <h2>Le périmètre, clairement posé</h2>
    </div>

    <div class="perimeter-grid">
      <div class="reveal">
        <h3 class="perimeter-title perimeter-in">Inclus dans chaque projet</h3>
        <ul class="perimeter-list" role="list">
          {inclus.map((item) => (
            <li class="perimeter-item">
              <span class="peri-icon peri-in" aria-hidden="true">✓</span>
              {item}
            </li>
          ))}
        </ul>
      </div>

      <div class="reveal">
        <h3 class="perimeter-title perimeter-out">Hors périmètre</h3>
        <ul class="perimeter-list" role="list">
          {exclus.map((item) => (
            <li class="perimeter-item">
              <span class="peri-icon peri-out" aria-hidden="true">✕</span>
              {item}
            </li>
          ))}
        </ul>
        <p class="perimeter-note">Si votre projet implique l'un de ces éléments, on vous dit en appel découverte vers qui vous orienter — sans vous laisser gérer ça seul.</p>
      </div>
    </div>
  </SectionWrapper>

  <!-- PROCESS DÉTAILLÉ -->
  <SectionWrapper bg="surface" size="md">
    <div class="section-header reveal">
      <h2>Comment on travaille — du premier appel à la livraison</h2>
      <p class="section-intro">3h30 de votre temps sur 4 à 6 semaines — réparties en 5 étapes. Voici le détail.</p>
    </div>

    <div class="process-list">
      {processData.map((step, i) => (
        <div class="reveal">
          <ProcessStep
            order={step.order}
            title={step.title}
            description={step.description}
            deliverable={step.deliverable}
            clientTime={step.clientTime}
            duration={step.duration}
            isLast={i === processData.length - 1}
          />
        </div>
      ))}
    </div>

    <div class="process-total reveal">
      <strong>Au total : 3h30 de votre temps sur 4 à 6 semaines.</strong>
      Réparties en 4 sessions courtes — jamais plus d'1h d'un coup. Entre les sessions : vous avez des livrables à valider, pas à produire.
    </div>
  </SectionWrapper>

  <!-- POUR QUI / PAS POUR QUI -->
  <SectionWrapper bg="muted" size="md">
    <div class="section-header reveal">
      <h2>Pour qui c'est — et pour qui ce n'est pas</h2>
    </div>

    <div class="qualification-grid">
      <div class="qual-col reveal">
        <h3 class="qual-label qual-yes">C'est fait pour vous si :</h3>
        <ul role="list" class="qual-list">
          {[
            "Vous dirigez une PME de services (2–50 pers) et votre présence digitale ne génère pas de demandes entrantes qualifiées.",
            "Vous avez un positionnement premium réel que votre image en ligne ne reflète pas encore.",
            "Vous voulez déléguer la partie digitale à un interlocuteur unique qui pense business.",
            "Vous êtes prêt à passer 3h30 structurées sur le projet — et pas plus.",
            "Vous voulez comprendre ce que vous achetez, étape par étape, avant de vous lancer.",
          ].map((item) => (
            <li class="qual-item"><span class="qi qi-yes">✓</span>{item}</li>
          ))}
        </ul>
      </div>
      <div class="qual-col reveal">
        <h3 class="qual-label qual-no">Ce n'est pas pour vous si :</h3>
        <ul role="list" class="qual-list">
          {[
            "Vous cherchez le site le moins cher et le plus rapide.",
            "Votre activité ou offre n'a pas encore d'objectif commercial clair.",
            "Vous devez valider chaque décision créative et chaque ligne de texte.",
            "Vous avez besoin d'un logiciel métier, d'une application mobile ou d'une plateforme SaaS.",
            "Vous n'avez ni contenus existants ni disponibilité pour les points d'étape.",
          ].map((item) => (
            <li class="qual-item"><span class="qi qi-no">✕</span>{item}</li>
          ))}
        </ul>
      </div>
    </div>
  </SectionWrapper>

  <!-- FAQ OFFRE -->
  <SectionWrapper bg="default" size="md">
    <div class="section-header reveal">
      <h2>Questions sur l'offre</h2>
    </div>
    <div class="reveal">
      <AccordionFAQ items={faqOffre} />
    </div>
  </SectionWrapper>

  <!-- CTA FINAL -->
  <SectionWrapper bg="surface" size="lg">
    <div class="cta-final reveal">
      <h2>Un appel pour évaluer ensemble.</h2>
      <p>En 30 minutes, vous savez si notre approche correspond à votre projet. Et si ce n'est pas le bon fit, on vous le dit clairement.</p>
      <div class="cta-row">
        <Button href={SITE.calendlyUrl} variant="primary" target="_blank" rel="noopener noreferrer">
          Réserver mon appel découverte
        </Button>
        <span class="cta-micro">Gratuit — sans engagement — réponse sous 24h</span>
      </div>
      <a href="/contact" class="cta-secondary-link">→ Demander un audit de mon site actuel</a>
    </div>
  </SectionWrapper>

</BaseLayout>

<style>
  .hero-offre {
    max-width: var(--max-width-prose);
    margin: 0 auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-6);
  }

  .hero-offre h1 { font-size: clamp(1.75rem, 4vw, 2.75rem); }
  .hero-sub { font-size: 1.125rem; color: var(--color-text-secondary); line-height: 1.7; }

  .hero-cta-row {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
  }

  .cta-micro { font-size: 0.8125rem; color: var(--color-text-secondary); }

  .section-header {
    max-width: var(--max-width-prose);
    margin: 0 auto var(--space-10);
    text-align: center;
  }

  .section-intro {
    margin-top: var(--space-4);
    font-size: 1.0625rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
  }

  .pillar-detail {
    max-width: 720px;
    margin: 0 auto;
  }

  .pillar-detail h3 {
    font-size: 1.25rem;
    margin-bottom: var(--space-3);
    color: var(--color-accent);
  }

  .pillar-detail p { margin-bottom: var(--space-4); }

  .detail-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
  }

  .detail-list li {
    padding-left: var(--space-6);
    position: relative;
    color: var(--color-text-secondary);
    font-size: 0.9375rem;
    line-height: 1.6;
  }

  .detail-list li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-weight: 600;
  }

  .not-this {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    background-color: var(--color-muted);
    border-left: 3px solid var(--color-border);
    padding: var(--space-3) var(--space-4);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
  }

  .section-divider {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: var(--space-10) 0;
  }

  .perimeter-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-8);
  }

  .perimeter-title {
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: var(--space-4);
    padding-bottom: var(--space-2);
    border-bottom: 2px solid;
  }

  .perimeter-in { color: var(--color-accent); border-color: var(--color-accent); }
  .perimeter-out { color: var(--color-text-secondary); border-color: var(--color-border); }

  .perimeter-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .perimeter-item {
    display: flex;
    gap: var(--space-3);
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  .peri-icon { font-weight: 700; flex-shrink: 0; margin-top: 2px; }
  .peri-in { color: var(--color-accent); }
  .peri-out { color: var(--color-text-secondary); opacity: 0.6; }

  .perimeter-note {
    margin-top: var(--space-6);
    font-size: 0.875rem;
    font-style: italic;
    color: var(--color-text-secondary);
  }

  .process-list { max-width: 640px; margin: 0 auto; }

  .process-total {
    max-width: 640px;
    margin: var(--space-8) auto 0;
    background-color: var(--color-muted);
    border: 1px solid var(--color-accent);
    border-radius: var(--radius-md);
    padding: var(--space-4) var(--space-6);
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
  }

  .qualification-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-8);
  }

  .qual-label {
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: var(--space-4);
    padding-bottom: var(--space-2);
    border-bottom: 2px solid;
  }

  .qual-yes { color: var(--color-accent); border-color: var(--color-accent); }
  .qual-no { color: var(--color-text-secondary); border-color: var(--color-border); }

  .qual-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .qual-item {
    display: flex;
    gap: var(--space-3);
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  .qi { font-weight: 700; flex-shrink: 0; margin-top: 2px; }
  .qi-yes { color: var(--color-accent); }
  .qi-no { color: var(--color-text-secondary); opacity: 0.6; }

  .cta-final {
    max-width: 600px;
    margin: 0 auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
  }

  .cta-row {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
  }

  .cta-secondary-link {
    font-size: 0.9375rem;
    color: var(--color-accent);
    font-weight: 500;
  }

  .cta-secondary-link:hover { color: var(--color-accent-hover); }

  @media (max-width: 768px) {
    .perimeter-grid, .qualification-grid { grid-template-columns: 1fr; }
  }
</style>
