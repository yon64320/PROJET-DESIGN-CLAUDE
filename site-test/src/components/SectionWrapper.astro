---
interface Props {
  id?: string;
  class?: string;
  bg?: 'default' | 'surface' | 'muted';
  size?: 'sm' | 'md' | 'lg';
}

const {
  id,
  class: className = '',
  bg = 'default',
  size = 'md',
} = Astro.props;

const bgClass = {
  default: 'bg-default',
  surface: 'bg-surface',
  muted: 'bg-muted',
}[bg];

const sizeClass = {
  sm: 'size-sm',
  md: 'size-md',
  lg: 'size-lg',
}[size];
---

<section id={id} class={`section-wrapper ${bgClass} ${sizeClass} ${className}`}>
  <div class="section-inner">
    <slot />
  </div>
</section>

<style>
  .section-wrapper {
    width: 100%;
  }

  .bg-default { background-color: var(--color-bg); }
  .bg-surface { background-color: var(--color-surface); }
  .bg-muted { background-color: var(--color-muted); }

  .section-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding-left: var(--space-6);
    padding-right: var(--space-6);
  }

  .size-sm .section-inner { padding-top: var(--space-12); padding-bottom: var(--space-12); }
  .size-md .section-inner { padding-top: var(--space-16); padding-bottom: var(--space-16); }
  .size-lg .section-inner { padding-top: var(--space-24); padding-bottom: var(--space-24); }

  @media (max-width: 768px) {
    .section-inner { padding-left: var(--space-4); padding-right: var(--space-4); }
    .size-sm .section-inner { padding-top: var(--space-8); padding-bottom: var(--space-8); }
    .size-md .section-inner { padding-top: var(--space-12); padding-bottom: var(--space-12); }
    .size-lg .section-inner { padding-top: var(--space-16); padding-bottom: var(--space-16); }
  }
</style>
