{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$version": "1.0.0",
  "$description": "HUGGO Design Tokens — W3C Design Tokens 2025.10 format. Source of truth: Oklch. sRGB hex fallbacks provided.",

  "color": {
    "$description": "Semantic color tokens — light mode values. Dark mode overrides in 'theme.dark' group.",

    "surface": {
      "primary": {
        "$type": "color",
        "$value": "oklch(0.98 0.005 90)",
        "$description": "Main page background — off-white warm",
        "$extensions": {
          "role": "Page background",
          "usage_context": "Body background, even-numbered section backgrounds",
          "do_not_use": "As text color",
          "paired_with": ["color.text.primary", "color.text.secondary"],
          "fallback_hex": "#FAFAF7"
        }
      },
      "secondary": {
        "$type": "color",
        "$value": "oklch(0.95 0.008 90)",
        "$description": "Alternating section background — slightly darker than primary",
        "$extensions": {
          "role": "Contrasted section background",
          "usage_context": "Odd-numbered sections, card elevated backgrounds, code blocks",
          "do_not_use": "As header/footer background",
          "paired_with": ["color.text.primary", "color.border.default"],
          "fallback_hex": "#F0F0EA"
        }
      },
      "elevated": {
        "$type": "color",
        "$value": "oklch(1.0 0 0)",
        "$description": "Elevated surfaces — cards, modals, dropdowns",
        "$extensions": {
          "role": "Card and elevated element background",
          "usage_context": "Cards, tooltips, mobile menu, form inputs, dropdowns",
          "do_not_use": "As main page background in light mode (identical appearance)",
          "paired_with": ["shadow.md", "color.border.default"],
          "fallback_hex": "#FFFFFF"
        }
      },
      "brand": {
        "$type": "color",
        "$value": "oklch(0.58 0.14 142)",
        "$description": "HUGGO green — branded surfaces (hero, header, footer, CTA bands)",
        "$extensions": {
          "role": "Brand identity surface",
          "usage_context": "Hero backgrounds, sticky header, footer, pré-footer CTA bands",
          "do_not_use": "For long body text areas (readability)",
          "paired_with": ["color.text.on-brand", "color.accent.action"],
          "fallback_hex": "#4A9B4A"
        }
      }
    },

    "text": {
      "primary": {
        "$type": "color",
        "$value": "oklch(0.20 0.005 210)",
        "$description": "Primary text — headings and body paragraphs",
        "$extensions": {
          "role": "Primary readable text",
          "usage_context": "H1-H6, paragraphs, list items, labels",
          "do_not_use": "On brand surfaces without contrast verification",
          "paired_with": ["color.surface.primary"],
          "fallback_hex": "#1A1D1E"
        }
      },
      "secondary": {
        "$type": "color",
        "$value": "oklch(0.48 0.01 230)",
        "$description": "Secondary text — captions, labels, micro-copy",
        "$extensions": {
          "role": "De-emphasized text",
          "usage_context": "Captions, dates, field labels, micro-copy under CTAs, placeholder text",
          "do_not_use": "For headings or CTA labels",
          "paired_with": ["color.surface.primary", "color.surface.secondary"],
          "fallback_hex": "#5A6066"
        }
      },
      "on-brand": {
        "$type": "color",
        "$value": "oklch(1.0 0 0)",
        "$description": "Text on brand green surfaces",
        "$extensions": {
          "role": "Light text on dark branded backgrounds",
          "usage_context": "Hero H1, header links, footer text, CTA text on green",
          "do_not_use": "On light backgrounds in light mode",
          "paired_with": ["color.surface.brand"],
          "fallback_hex": "#FFFFFF"
        }
      },
      "on-accent": {
        "$type": "color",
        "$value": "oklch(1.0 0 0)",
        "$description": "Text on accent orange surfaces",
        "$extensions": {
          "role": "Label text on CTA buttons",
          "usage_context": "Primary CTA button labels",
          "do_not_use": "On non-accent backgrounds",
          "paired_with": ["color.accent.action"],
          "fallback_hex": "#FFFFFF"
        }
      }
    },

    "accent": {
      "action": {
        "$type": "color",
        "$value": "oklch(0.73 0.17 70)",
        "$description": "HUGGO orange — primary action color (CTAs, highlights)",
        "$extensions": {
          "role": "Primary call-to-action",
          "usage_context": "Primary buttons, active links, key metric highlights, badges",
          "do_not_use": "As section background color",
          "paired_with": ["color.text.on-accent"],
          "fallback_hex": "#F5920A"
        }
      },
      "action-hover": {
        "$type": "color",
        "$value": "oklch(0.68 0.17 70)",
        "$description": "Hover state for primary action",
        "$extensions": {
          "role": "CTA hover state",
          "usage_context": "Primary button hover",
          "do_not_use": "Outside hover context",
          "paired_with": ["color.accent.action"],
          "fallback_hex": "#E08209"
        }
      },
      "action-pressed": {
        "$type": "color",
        "$value": "oklch(0.63 0.17 70)",
        "$description": "Pressed/active state for primary action",
        "$extensions": {
          "role": "CTA active/pressed state",
          "usage_context": "Primary button active/pressed",
          "do_not_use": "Outside pressed context",
          "paired_with": ["color.accent.action"],
          "fallback_hex": "#CC7408"
        }
      },
      "subtle": {
        "$type": "color",
        "$value": "oklch(0.90 0.06 70)",
        "$description": "Subtle accent background for badges and indicators",
        "$extensions": {
          "role": "Low-emphasis accent surface",
          "usage_context": "Badge backgrounds, tag backgrounds, indicator backgrounds",
          "do_not_use": "As text color",
          "paired_with": ["color.text.primary", "color.accent.action"],
          "fallback_hex": "#FDE8C8"
        }
      }
    },

    "brand": {
      "primary": {
        "$type": "color",
        "$value": "oklch(0.58 0.14 142)",
        "$description": "HUGGO green — brand identity token",
        "$extensions": {
          "role": "Brand identity color",
          "usage_context": "Logos, branded icons, header, trust badges, secondary buttons",
          "do_not_use": "As body text color on light backgrounds (insufficient contrast)",
          "paired_with": ["color.text.on-brand"],
          "fallback_hex": "#4A9B4A"
        }
      },
      "primary-hover": {
        "$type": "color",
        "$value": "oklch(0.53 0.14 142)",
        "$description": "Hover state for brand elements",
        "$extensions": {
          "role": "Brand hover state",
          "usage_context": "Header link hover, secondary button hover",
          "do_not_use": "Outside hover context",
          "paired_with": ["color.brand.primary"],
          "fallback_hex": "#3F8A3F"
        }
      }
    },

    "feedback": {
      "success": {
        "$type": "color",
        "$value": "oklch(0.52 0.14 150)",
        "$description": "Success feedback — form submissions, validations",
        "$extensions": {
          "role": "Success state indicator",
          "usage_context": "Form success messages, validation checkmarks, success borders",
          "do_not_use": "As decorative color",
          "paired_with": ["color.surface.primary"],
          "fallback_hex": "#2E8540"
        }
      },
      "error": {
        "$type": "color",
        "$value": "oklch(0.50 0.19 25)",
        "$description": "Error feedback — form errors, invalid states",
        "$extensions": {
          "role": "Error state indicator",
          "usage_context": "Form error messages, invalid field borders, error icons",
          "do_not_use": "As decorative color",
          "paired_with": ["color.surface.primary"],
          "fallback_hex": "#D32F2F"
        }
      },
      "warning": {
        "$type": "color",
        "$value": "oklch(0.76 0.15 80)",
        "$description": "Warning feedback — incomplete fields, caution states",
        "$extensions": {
          "role": "Warning state indicator",
          "usage_context": "Warning messages, incomplete field indicators",
          "do_not_use": "As main background color",
          "paired_with": ["color.text.primary"],
          "fallback_hex": "#F9A825"
        }
      }
    },

    "border": {
      "default": {
        "$type": "color",
        "$value": "oklch(0.90 0.005 230)",
        "$description": "Default border — cards, separators, form fields",
        "$extensions": {
          "role": "Structural border",
          "usage_context": "Card borders, section separators, form field borders, table borders",
          "do_not_use": "As text color",
          "paired_with": ["color.surface.elevated", "color.surface.secondary"],
          "fallback_hex": "#E0E2E4"
        }
      },
      "focus": {
        "$type": "color",
        "$value": "oklch(0.73 0.17 70)",
        "$description": "Focus ring border — keyboard navigation indicator",
        "$extensions": {
          "role": "Accessibility focus indicator",
          "usage_context": "Focus ring (2px, offset 2px) on all interactive elements",
          "do_not_use": "Outside focus state context",
          "paired_with": ["color.accent.action"],
          "fallback_hex": "#F5920A"
        }
      }
    }
  },

  "theme": {
    "dark": {
      "$description": "Dark mode overrides — only tokens that change between themes",

      "color": {
        "surface": {
          "primary": {
            "$type": "color",
            "$value": "oklch(0.15 0.005 210)",
            "$extensions": { "fallback_hex": "#121516" }
          },
          "secondary": {
            "$type": "color",
            "$value": "oklch(0.20 0.005 210)",
            "$extensions": { "fallback_hex": "#1A1D1E" }
          },
          "elevated": {
            "$type": "color",
            "$value": "oklch(0.25 0.008 210)",
            "$extensions": { "fallback_hex": "#252A2C" }
          },
          "brand": {
            "$type": "color",
            "$value": "oklch(0.45 0.12 142)",
            "$extensions": { "fallback_hex": "#357835" }
          }
        },
        "text": {
          "primary": {
            "$type": "color",
            "$value": "oklch(0.95 0.005 90)",
            "$extensions": { "fallback_hex": "#F0F0EA" }
          },
          "secondary": {
            "$type": "color",
            "$value": "oklch(0.65 0.01 230)",
            "$extensions": { "fallback_hex": "#8A9099" }
          },
          "on-brand": {
            "$type": "color",
            "$value": "oklch(1.0 0 0)",
            "$extensions": { "fallback_hex": "#FFFFFF" }
          },
          "on-accent": {
            "$type": "color",
            "$value": "oklch(0.13 0.01 70)",
            "$extensions": { "fallback_hex": "#1A1208" }
          }
        },
        "accent": {
          "action": {
            "$type": "color",
            "$value": "oklch(0.70 0.15 70)",
            "$extensions": { "fallback_hex": "#E58A0A" }
          },
          "action-hover": {
            "$type": "color",
            "$value": "oklch(0.65 0.15 70)",
            "$extensions": { "fallback_hex": "#D07A09" }
          },
          "action-pressed": {
            "$type": "color",
            "$value": "oklch(0.60 0.15 70)",
            "$extensions": { "fallback_hex": "#BB6B08" }
          },
          "subtle": {
            "$type": "color",
            "$value": "oklch(0.30 0.06 70)",
            "$extensions": { "fallback_hex": "#3D3020" }
          }
        },
        "brand": {
          "primary": {
            "$type": "color",
            "$value": "oklch(0.55 0.12 142)",
            "$extensions": { "fallback_hex": "#438E43" }
          },
          "primary-hover": {
            "$type": "color",
            "$value": "oklch(0.50 0.12 142)",
            "$extensions": { "fallback_hex": "#38803C" }
          }
        },
        "feedback": {
          "success": {
            "$type": "color",
            "$value": "oklch(0.58 0.12 150)",
            "$extensions": { "fallback_hex": "#3A9A4A" }
          },
          "error": {
            "$type": "color",
            "$value": "oklch(0.55 0.17 25)",
            "$extensions": { "fallback_hex": "#E04040" }
          },
          "warning": {
            "$type": "color",
            "$value": "oklch(0.72 0.13 80)",
            "$extensions": { "fallback_hex": "#E89520" }
          }
        },
        "border": {
          "default": {
            "$type": "color",
            "$value": "oklch(0.30 0.005 230)",
            "$extensions": { "fallback_hex": "#3A3E42" }
          },
          "focus": {
            "$type": "color",
            "$value": "oklch(0.70 0.15 70)",
            "$extensions": { "fallback_hex": "#E58A0A" }
          }
        }
      },

      "shadow": {
        "sm": {
          "$type": "shadow",
          "$value": "0 1px 2px oklch(0 0 0 / 0.3)",
          "$extensions": { "fallback": "0 1px 2px rgba(0,0,0,0.3)" }
        },
        "md": {
          "$type": "shadow",
          "$value": "0 4px 12px oklch(0 0 0 / 0.4)",
          "$extensions": { "fallback": "0 4px 12px rgba(0,0,0,0.4)" }
        },
        "lg": {
          "$type": "shadow",
          "$value": "0 8px 24px oklch(0 0 0 / 0.5)",
          "$extensions": { "fallback": "0 8px 24px rgba(0,0,0,0.5)" }
        },
        "xl": {
          "$type": "shadow",
          "$value": "0 16px 48px oklch(0 0 0 / 0.6)",
          "$extensions": { "fallback": "0 16px 48px rgba(0,0,0,0.6)" }
        },
        "accent-glow": {
          "$type": "shadow",
          "$value": "0 4px 20px oklch(0.70 0.15 70 / 0.35)",
          "$extensions": { "fallback": "0 4px 20px rgba(229,138,10,0.35)" }
        }
      }
    }
  },

  "typography": {
    "family": {
      "display": {
        "$type": "fontFamily",
        "$value": ["Plus Jakarta Sans", "system-ui", "sans-serif"],
        "$description": "Display and heading typeface — geometric, bold, accessible character",
        "$extensions": {
          "role": "Heading typeface",
          "usage_context": "H1-H4, display text, hero titles",
          "do_not_use": "Body paragraphs, captions",
          "paired_with": ["typography.family.body"]
        }
      },
      "body": {
        "$type": "fontFamily",
        "$value": ["DM Sans", "system-ui", "sans-serif"],
        "$description": "Body typeface — high x-height, excellent readability",
        "$extensions": {
          "role": "Body text typeface",
          "usage_context": "Paragraphs, lists, labels, micro-copy, buttons",
          "do_not_use": "Large display headings",
          "paired_with": ["typography.family.display"]
        }
      },
      "mono": {
        "$type": "fontFamily",
        "$value": ["JetBrains Mono", "monospace"],
        "$description": "Monospace typeface for data/metrics display",
        "$extensions": {
          "role": "Data display typeface",
          "usage_context": "Key metrics (15M, 0%, +30%), data tables",
          "do_not_use": "Body text, headings",
          "paired_with": ["color.accent.action"]
        }
      }
    },

    "scale": {
      "display-xl": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{typography.family.display}",
          "fontSize": "3.5rem",
          "lineHeight": "1.1",
          "fontWeight": 700,
          "letterSpacing": "-0.02em"
        },
        "$description": "Hero H1 — homepage only",
        "$extensions": {
          "role": "Primary hero headline",
          "usage_context": "H1 on homepage hero section only",
          "do_not_use": "Sub-headings, body text, internal page H1",
          "paired_with": ["spacing.section"],
          "responsive": "clamp(2.25rem, 5vw, 3.5rem)"
        }
      },
      "display-lg": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{typography.family.display}",
          "fontSize": "2.75rem",
          "lineHeight": "1.15",
          "fontWeight": 700,
          "letterSpacing": "-0.01em"
        },
        "$description": "H1 for internal pages",
        "$extensions": {
          "role": "Internal page headline",
          "usage_context": "H1 on Retail, Franchise, Collectivity, How-it-works, Pricing, About, Contact",
          "do_not_use": "Homepage H1, body text",
          "paired_with": ["spacing.section"],
          "responsive": "clamp(1.875rem, 4vw, 2.75rem)"
        }
      },
      "heading-xl": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{typography.family.display}",
          "fontSize": "2.25rem",
          "lineHeight": "1.2",
          "fontWeight": 700,
          "letterSpacing": "-0.01em"
        },
        "$description": "H2 section headings",
        "$extensions": {
          "role": "Section heading",
          "usage_context": "H2 headings for main sections across all pages",
          "do_not_use": "H1, body text",
          "paired_with": ["spacing.component"],
          "responsive": "clamp(1.625rem, 3.5vw, 2.25rem)"
        }
      },
      "heading-lg": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{typography.family.display}",
          "fontSize": "1.75rem",
          "lineHeight": "1.25",
          "fontWeight": 600,
          "letterSpacing": "0"
        },
        "$description": "H3 sub-section headings",
        "$extensions": {
          "role": "Sub-section heading",
          "usage_context": "H3 sub-headings (benefits, pricing tiers, FAQ questions)",
          "do_not_use": "H1-H2, body text",
          "paired_with": ["spacing.component"],
          "responsive": "clamp(1.375rem, 3vw, 1.75rem)"
        }
      },
      "heading-md": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{typography.family.display}",
          "fontSize": "1.375rem",
          "lineHeight": "1.3",
          "fontWeight": 600,
          "letterSpacing": "0"
        },
        "$description": "H4 element headings",
        "$extensions": {
          "role": "Element heading",
          "usage_context": "Tier labels, feature names, stat labels",
          "do_not_use": "Paragraphs",
          "paired_with": ["spacing.element"]
        }
      },
      "heading-sm": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{typography.family.body}",
          "fontSize": "1.125rem",
          "lineHeight": "1.4",
          "fontWeight": 600,
          "letterSpacing": "0.01em"
        },
        "$description": "H5-H6, overlines",
        "$extensions": {
          "role": "Overline / minor heading",
          "usage_context": "Section overlines (Retail, Franchise), minor labels, H5-H6",
          "do_not_use": "Body text (same size but different weight)",
          "paired_with": ["spacing.element"]
        }
      },
      "body-lg": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{typography.family.body}",
          "fontSize": "1.125rem",
          "lineHeight": "1.6",
          "fontWeight": 400,
          "letterSpacing": "0"
        },
        "$description": "Large body — hero subtitles, lead paragraphs",
        "$extensions": {
          "role": "Lead paragraph text",
          "usage_context": "Hero subtitles, lead paragraphs, important body sections",
          "do_not_use": "Headings, captions",
          "paired_with": ["spacing.element"]
        }
      },
      "body-md": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{typography.family.body}",
          "fontSize": "1rem",
          "lineHeight": "1.6",
          "fontWeight": 400,
          "letterSpacing": "0"
        },
        "$description": "Default body text",
        "$extensions": {
          "role": "Standard readable text",
          "usage_context": "Paragraphs, lists, descriptions, FAQ answers",
          "do_not_use": "Headings",
          "paired_with": ["spacing.element"]
        }
      },
      "body-sm": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{typography.family.body}",
          "fontSize": "0.875rem",
          "lineHeight": "1.5",
          "fontWeight": 400,
          "letterSpacing": "0.01em"
        },
        "$description": "Small body — micro-copy, labels, captions",
        "$extensions": {
          "role": "Supporting text",
          "usage_context": "CTA micro-copy, field labels, long captions",
          "do_not_use": "Headings, mobile body (too small for primary reading)",
          "paired_with": ["spacing.element"]
        }
      },
      "caption": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{typography.family.body}",
          "fontSize": "0.75rem",
          "lineHeight": "1.4",
          "fontWeight": 400,
          "letterSpacing": "0.02em"
        },
        "$description": "Captions, legal text, copyright",
        "$extensions": {
          "role": "Smallest readable text",
          "usage_context": "Copyright footer, source citations, legal mentions",
          "do_not_use": "Body text, labels (too small)",
          "paired_with": ["color.text.secondary"]
        }
      },
      "data-xl": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{typography.family.mono}",
          "fontSize": "3rem",
          "lineHeight": "1.1",
          "fontWeight": 700,
          "letterSpacing": "-0.02em"
        },
        "$description": "Large data display — hero metrics (15M, 0%)",
        "$extensions": {
          "role": "Primary metric display",
          "usage_context": "Key metrics on homepage chiffres section (15M, 0%, 60%)",
          "do_not_use": "Body text, headings",
          "paired_with": ["color.accent.action", "typography.scale.body-sm"],
          "responsive": "clamp(2rem, 4.5vw, 3rem)"
        }
      },
      "data-lg": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{typography.family.mono}",
          "fontSize": "2.25rem",
          "lineHeight": "1.15",
          "fontWeight": 700,
          "letterSpacing": "-0.01em"
        },
        "$description": "Medium data display — section metrics",
        "$extensions": {
          "role": "Secondary metric display",
          "usage_context": "Metrics on vertical pages, results sections (+15-30%)",
          "do_not_use": "Body text",
          "paired_with": ["color.accent.action", "typography.scale.body-sm"],
          "responsive": "clamp(1.625rem, 3.5vw, 2.25rem)"
        }
      },
      "button": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{typography.family.body}",
          "fontSize": "1rem",
          "lineHeight": "1",
          "fontWeight": 600,
          "letterSpacing": "0.02em"
        },
        "$description": "Button label text",
        "$extensions": {
          "role": "Interactive element label",
          "usage_context": "CTA button labels (primary, secondary, tertiary)",
          "do_not_use": "Paragraphs",
          "paired_with": ["color.accent.action", "color.brand.primary"]
        }
      }
    }
  },

  "spacing": {
    "section": {
      "$type": "dimension",
      "$value": "6rem",
      "$description": "Spacing between page sections (96px)",
      "$extensions": {
        "role": "Section-level spacing",
        "usage_context": "Margin-top/bottom between main page sections",
        "do_not_use": "Inside a component",
        "paired_with": ["typography.scale.heading-xl", "typography.scale.display-xl"],
        "responsive_mobile": "4rem"
      }
    },
    "section-sm": {
      "$type": "dimension",
      "$value": "4rem",
      "$description": "Compact section spacing (64px)",
      "$extensions": {
        "role": "Compact section spacing",
        "usage_context": "Shorter sections (FAQ, pré-footer CTA, footer)",
        "do_not_use": "Between intra-section components",
        "paired_with": ["typography.scale.heading-lg"],
        "responsive_mobile": "3rem"
      }
    },
    "component": {
      "$type": "dimension",
      "$value": "2rem",
      "$description": "Spacing between components (32px)",
      "$extensions": {
        "role": "Component-level spacing",
        "usage_context": "Gap between cards, benefit blocks, FAQ items",
        "do_not_use": "Inside an atomic component",
        "paired_with": ["typography.scale.heading-lg", "typography.scale.body-lg"]
      }
    },
    "component-sm": {
      "$type": "dimension",
      "$value": "1.5rem",
      "$description": "Compact component spacing (24px)",
      "$extensions": {
        "role": "Compact component spacing",
        "usage_context": "Card internal gap, card padding, feature list spacing",
        "do_not_use": "Between sections",
        "paired_with": ["typography.scale.body-md"]
      }
    },
    "element": {
      "$type": "dimension",
      "$value": "1rem",
      "$description": "Element-level spacing (16px)",
      "$extensions": {
        "role": "Element-level spacing",
        "usage_context": "Gap between paragraph and CTA, label and field, icon and text",
        "do_not_use": "Between sections",
        "paired_with": ["typography.scale.body-md", "typography.scale.body-sm"]
      }
    },
    "element-sm": {
      "$type": "dimension",
      "$value": "0.75rem",
      "$description": "Compact element spacing (12px)",
      "$extensions": {
        "role": "Compact element spacing",
        "usage_context": "Badge internal padding, micro-element gaps",
        "do_not_use": "Between components",
        "paired_with": ["typography.scale.caption"]
      }
    },
    "element-xs": {
      "$type": "dimension",
      "$value": "0.5rem",
      "$description": "Minimal element spacing (8px)",
      "$extensions": {
        "role": "Minimal spacing",
        "usage_context": "Inline icon-to-text gap, tag internal padding",
        "do_not_use": "As visible section spacing",
        "paired_with": ["typography.scale.body-sm"]
      }
    },
    "element-2xs": {
      "$type": "dimension",
      "$value": "0.25rem",
      "$description": "Micro spacing (4px)",
      "$extensions": {
        "role": "Micro spacing",
        "usage_context": "Intimately related elements (label + asterisk, icon + badge count)",
        "do_not_use": "As main visible spacing",
        "paired_with": []
      }
    }
  },

  "radius": {
    "none": {
      "$type": "dimension",
      "$value": "0",
      "$description": "No radius — full-width elements",
      "$extensions": {
        "role": "Sharp corners",
        "usage_context": "Full-width sections, CTA bands",
        "do_not_use": "Cards, buttons"
      }
    },
    "sm": {
      "$type": "dimension",
      "$value": "0.5rem",
      "$description": "Slight rounding (8px)",
      "$extensions": {
        "role": "Subtle rounding",
        "usage_context": "Form fields, badges, tags",
        "do_not_use": "Main cards"
      }
    },
    "md": {
      "$type": "dimension",
      "$value": "0.75rem",
      "$description": "Standard rounding (12px)",
      "$extensions": {
        "role": "Standard rounding",
        "usage_context": "Cards, accordions, visual containers",
        "do_not_use": "Buttons (too small for Obypay style)"
      }
    },
    "lg": {
      "$type": "dimension",
      "$value": "1.25rem",
      "$description": "Pronounced rounding (20px) — Obypay button style",
      "$extensions": {
        "role": "Pronounced rounding",
        "usage_context": "CTA buttons, nav pills, toggles",
        "do_not_use": "Full-width sections"
      }
    },
    "xl": {
      "$type": "dimension",
      "$value": "1.5rem",
      "$description": "Large rounding (24px)",
      "$extensions": {
        "role": "Large rounding",
        "usage_context": "Hero cards, 3D container, modals",
        "do_not_use": "Small elements"
      }
    },
    "full": {
      "$type": "dimension",
      "$value": "9999px",
      "$description": "Full circle / pill shape",
      "$extensions": {
        "role": "Circle or pill",
        "usage_context": "WhatsApp floating button, avatars, round tags",
        "do_not_use": "Cards, wide containers"
      }
    }
  },

  "shadow": {
    "sm": {
      "$type": "shadow",
      "$value": "0 1px 2px oklch(0.20 0 0 / 0.05)",
      "$description": "Low elevation — form fields, badges",
      "$extensions": {
        "fallback": "0 1px 2px rgba(26,29,30,0.05)"
      }
    },
    "md": {
      "$type": "shadow",
      "$value": "0 4px 12px oklch(0.20 0 0 / 0.08)",
      "$description": "Medium elevation — cards, dropdowns, button hover",
      "$extensions": {
        "fallback": "0 4px 12px rgba(26,29,30,0.08)"
      }
    },
    "lg": {
      "$type": "shadow",
      "$value": "0 8px 24px oklch(0.20 0 0 / 0.12)",
      "$description": "High elevation — modals, sticky header, mobile menu",
      "$extensions": {
        "fallback": "0 8px 24px rgba(26,29,30,0.12)"
      }
    },
    "xl": {
      "$type": "shadow",
      "$value": "0 16px 48px oklch(0.20 0 0 / 0.16)",
      "$description": "Maximum elevation — tooltips, popovers",
      "$extensions": {
        "fallback": "0 16px 48px rgba(26,29,30,0.16)"
      }
    },
    "accent-glow": {
      "$type": "shadow",
      "$value": "0 4px 20px oklch(0.73 0.17 70 / 0.25)",
      "$description": "Accent glow on CTA hover and WhatsApp button",
      "$extensions": {
        "fallback": "0 4px 20px rgba(245,146,10,0.25)"
      }
    }
  },

  "grid": {
    "columns": {
      "$type": "number",
      "$value": 12,
      "$description": "Grid column count"
    },
    "gutter": {
      "$type": "dimension",
      "$value": "1.5rem",
      "$description": "Gap between grid columns (24px)"
    },
    "margin": {
      "$type": "dimension",
      "$value": "1.5rem",
      "$description": "Grid margin — mobile default (24px). Tablet: 3rem, Desktop: 5rem",
      "$extensions": {
        "responsive": {
          "sm": "1.5rem",
          "md": "3rem",
          "lg": "5rem"
        }
      }
    },
    "max-width": {
      "$type": "dimension",
      "$value": "80rem",
      "$description": "Maximum content width (1280px)"
    }
  },

  "motion": {
    "duration": {
      "instant": {
        "$type": "duration",
        "$value": "100ms",
        "$description": "Pressed/active feedback"
      },
      "fast": {
        "$type": "duration",
        "$value": "150ms",
        "$description": "Micro-interactions (hover, focus, press)"
      },
      "normal": {
        "$type": "duration",
        "$value": "250ms",
        "$description": "State transitions (accordion, tab switch)"
      },
      "slow": {
        "$type": "duration",
        "$value": "400ms",
        "$description": "Scroll-triggered entrance animations"
      },
      "slower": {
        "$type": "duration",
        "$value": "500ms",
        "$description": "Maximum entrance animation duration"
      }
    },
    "easing": {
      "default": {
        "$type": "cubicBezier",
        "$value": [0.25, 0.1, 0.25, 1],
        "$description": "Default ease-out for micro-interactions"
      },
      "in-out": {
        "$type": "cubicBezier",
        "$value": [0.42, 0, 0.58, 1],
        "$description": "Ease-in-out for state transitions"
      },
      "spring": {
        "$type": "cubicBezier",
        "$value": [0.16, 1, 0.3, 1],
        "$description": "Spring-like ease for scroll-triggered entrances"
      },
      "linear": {
        "$type": "cubicBezier",
        "$value": [0, 0, 1, 1],
        "$description": "Linear for continuous animations (logo bar scroll)"
      }
    }
  }
}
