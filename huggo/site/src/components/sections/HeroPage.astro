---
import { getLocalePath } from '../../utils/i18n';

interface Props {
  locale: 'fr' | 'en';
  h1: string;
  subtitle: string;
  ctaPrimary: string;
  ctaPrimaryHref?: string;
  ctaSecondary?: string;
  ctaSecondaryHref?: string;
  microText?: string;
  branded?: boolean;
}

const {
  locale,
  h1,
  subtitle,
  ctaPrimary,
  ctaPrimaryHref,
  ctaSecondary,
  ctaSecondaryHref,
  microText,
  branded = false,
} = Astro.props;

const defaultHref = getLocalePath(locale, 'contact');
---

<section class="relative overflow-hidden" style={branded ? 'background-color: var(--color-surface-brand);' : 'background-color: var(--color-surface-primary);'}>
  <!-- Decorative elements -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
    <div class="absolute -top-20 -right-20 w-[400px] h-[400px] rounded-full opacity-10" style={`background: radial-gradient(circle, ${branded ? 'white' : 'var(--color-accent-action)'} 0%, transparent 70%);`}></div>
    <div class="absolute -bottom-20 -left-20 w-[300px] h-[300px] rounded-full opacity-10" style={`background: radial-gradient(circle, ${branded ? 'white' : 'var(--color-brand-primary)'} 0%, transparent 70%);`}></div>
  </div>

  <div class="container relative z-10 max-w-4xl text-center py-20 lg:py-28">
    <h1 class="font-display font-bold leading-tight mb-5 css-fade-up" style={`font-size: clamp(1.875rem, 4vw, 2.75rem); color: ${branded ? 'white' : 'var(--color-text-primary)'};`}>
      {h1}
    </h1>
    <p class={`text-lg leading-relaxed mb-10 max-w-2xl mx-auto css-fade-up css-fade-up-delay-1`} style={`color: ${branded ? 'rgba(255,255,255,0.85)' : 'var(--color-text-secondary)'};`}>
      {subtitle}
    </p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 css-fade-up css-fade-up-delay-2">
      <a
        href={ctaPrimaryHref || defaultHref}
        class="inline-flex items-center justify-center gap-2 px-8 h-[50px] bg-[var(--color-accent-action)] text-white font-semibold text-[0.9375rem] tracking-wide rounded-[20px] hover:bg-[var(--color-accent-action-hover)] hover:shadow-[0_4px_20px_rgba(245,146,10,0.35)] active:scale-[0.97] transition-all duration-150 group w-full sm:w-auto"
        data-analytics="cta_demo_click"
        data-position="hero"
      >
        {ctaPrimary}
        <svg class="w-4 h-4 transition-transform duration-150 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
      {ctaSecondary && (
        <a
          href={ctaSecondaryHref || defaultHref}
          class={`inline-flex items-center justify-center gap-2 px-6 h-[50px] border-2 rounded-[20px] font-semibold text-[0.9375rem] active:scale-[0.97] transition-all duration-150 w-full sm:w-auto ${branded ? 'border-white/30 text-white hover:bg-white/10' : 'hover:bg-[var(--color-brand-primary)]/[0.08]'}`}
          style={branded ? '' : 'border-color: var(--color-brand-primary); color: var(--color-brand-primary);'}
        >
          {ctaSecondary}
        </a>
      )}
    </div>
    {microText && (
      <p class="text-sm mt-4 css-fade-up css-fade-up-delay-3" style="color: var(--color-text-secondary);">{microText}</p>
    )}
  </div>
</section>
