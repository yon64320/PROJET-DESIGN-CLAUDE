---
import { getLocalePath } from '../../utils/i18n';

interface Props {
  locale: 'fr' | 'en';
}

const { locale } = Astro.props;
const altLocale = locale === 'fr' ? 'en' : 'fr';

const nav = locale === 'fr'
  ? [
      { label: 'Retail', href: getLocalePath(locale, 'retail') },
      { label: 'Franchise', href: getLocalePath(locale, 'franchise') },
      { label: 'Collectivity', href: getLocalePath(locale, 'collectivity') },
      { label: 'Comment ça marche', href: getLocalePath(locale, 'how-it-works') },
      { label: 'Tarifs', href: getLocalePath(locale, 'pricing') },
      { label: 'À propos', href: getLocalePath(locale, 'about') },
    ]
  : [
      { label: 'Retail', href: getLocalePath(locale, 'retail') },
      { label: 'Franchise', href: getLocalePath(locale, 'franchise') },
      { label: 'Collectivity', href: getLocalePath(locale, 'collectivity') },
      { label: 'How it works', href: getLocalePath(locale, 'how-it-works') },
      { label: 'Pricing', href: getLocalePath(locale, 'pricing') },
      { label: 'About', href: getLocalePath(locale, 'about') },
    ];

const ctaLabel = locale === 'fr' ? 'Demander une démo' : 'Request a demo';
const langToggleLabel = locale === 'fr' ? 'EN' : 'FR';
const langToggleAria = locale === 'fr' ? 'Basculer vers l\'anglais' : 'Switch to French';
const darkModeAria = locale === 'fr' ? 'Activer le mode sombre' : 'Enable dark mode';
const hamburgerAria = locale === 'fr' ? 'Ouvrir le menu' : 'Open menu';

// Build the alternate URL for the current page
const currentPath = Astro.url.pathname.replace(`/${locale}`, '');
const altHref = getLocalePath(altLocale, currentPath);
---

<header
  class="fixed top-0 left-0 right-0 z-40 header-compact"
  id="site-header"
  style="background-color: var(--color-surface-brand);"
>
  <div class="container flex items-center justify-between transition-[height] duration-200 ease-out" id="header-inner" style="height: 72px;">
    <!-- Logo -->
    <a href={getLocalePath(locale)} class="flex-shrink-0 group">
      <span class="text-2xl font-bold font-display tracking-tight text-white transition-transform duration-150 group-hover:scale-105 inline-block">huggo</span>
    </a>

    <!-- Desktop Navigation -->
    <nav class="hidden lg:flex items-center gap-1" aria-label={locale === 'fr' ? 'Navigation principale' : 'Main navigation'}>
      {nav.map((item) => (
        <a
          href={item.href}
          class="relative px-3 py-2 text-[0.9375rem] text-white/90 hover:text-white transition-colors duration-150 rounded-lg hover:bg-white/10"
        >
          {item.label}
        </a>
      ))}
    </nav>

    <!-- Desktop Actions -->
    <div class="hidden lg:flex items-center gap-3">
      <!-- Language toggle -->
      <a
        href={altHref}
        class="px-3 py-1.5 text-sm font-semibold text-white/80 hover:text-white border border-white/20 rounded-lg hover:bg-white/10 transition-all duration-150"
        aria-label={langToggleAria}
      >
        {langToggleLabel}
      </a>

      <!-- Dark mode toggle -->
      <button
        id="dark-mode-toggle"
        class="p-2 rounded-lg text-white/80 hover:text-white hover:bg-white/10 transition-all duration-150"
        aria-label={darkModeAria}
        type="button"
      >
        <svg class="w-5 h-5 dark-icon-sun" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
        </svg>
        <svg class="w-5 h-5 dark-icon-moon hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
        </svg>
      </button>

      <!-- CTA Button -->
      <a
        href={getLocalePath(locale, 'contact')}
        class="inline-flex items-center gap-2 px-6 h-[46px] bg-[var(--color-accent-action)] text-white font-semibold text-[0.9375rem] tracking-wide rounded-[20px] hover:bg-[var(--color-accent-action-hover)] hover:shadow-[0_4px_20px_rgba(245,146,10,0.35)] active:scale-[0.97] transition-all duration-150 group"
        data-analytics="cta_demo_click"
        data-position="header"
      >
        {ctaLabel}
        <svg class="w-4 h-4 transition-transform duration-150 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
    </div>

    <!-- Mobile: CTA + Hamburger -->
    <div class="flex lg:hidden items-center gap-2">
      <a
        href={getLocalePath(locale, 'contact')}
        class="inline-flex items-center px-4 h-[40px] bg-[var(--color-accent-action)] text-white font-semibold text-sm rounded-[20px] active:scale-[0.97] transition-all duration-150"
      >
        {ctaLabel}
      </a>
      <button
        id="mobile-menu-btn"
        class="p-2 rounded-lg text-white hover:bg-white/10 transition-colors duration-150"
        aria-label={hamburgerAria}
        aria-expanded="false"
        aria-controls="mobile-menu"
        type="button"
      >
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" id="hamburger-icon" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu Overlay -->
  <div
    id="mobile-menu"
    class="hidden lg:hidden fixed inset-0 top-[72px] z-50 menu-overlay"
    style="background-color: var(--color-surface-brand);"
    role="dialog"
    aria-modal="true"
  >
    <nav class="container flex flex-col gap-2 py-8" aria-label={locale === 'fr' ? 'Navigation mobile' : 'Mobile navigation'}>
      {nav.map((item) => (
        <a
          href={item.href}
          class="text-lg text-white/90 hover:text-white hover:bg-white/10 rounded-xl px-4 py-3 transition-all duration-150"
        >
          {item.label}
        </a>
      ))}
      <div class="flex items-center gap-4 pt-6 mt-4 border-t border-white/20">
        <a href={altHref} class="px-4 py-2 text-sm font-semibold text-white border border-white/20 rounded-lg hover:bg-white/10 transition-all" aria-label={langToggleAria}>
          {langToggleLabel}
        </a>
        <button id="dark-mode-toggle-mobile" class="p-2 text-white/80 hover:text-white rounded-lg hover:bg-white/10 transition-all" aria-label={darkModeAria} type="button">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
          </svg>
        </button>
      </div>
    </nav>
  </div>
</header>

<!-- Spacer for fixed header -->
<div class="h-[72px]"></div>

<script>
  import { initDarkModeToggle } from '../../utils/dark-mode';

  // Header compact on scroll
  const header = document.getElementById('site-header');
  const headerInner = document.getElementById('header-inner');

  if (header && headerInner) {
    window.addEventListener('scroll', () => {
      if (window.scrollY > 50) {
        headerInner.style.height = '56px';
        header.style.backdropFilter = 'blur(16px)';
        header.style.webkitBackdropFilter = 'blur(16px)';
        header.style.boxShadow = '0 4px 30px rgba(0,0,0,0.15)';
        header.style.backgroundColor = 'color-mix(in srgb, var(--color-surface-brand) 85%, transparent)';
      } else {
        headerInner.style.height = '72px';
        header.style.backdropFilter = 'none';
        header.style.webkitBackdropFilter = 'none';
        header.style.boxShadow = 'none';
        header.style.backgroundColor = 'var(--color-surface-brand)';
      }
    }, { passive: true });
  }

  // Mobile menu toggle
  const menuBtn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');

  if (menuBtn && menu) {
    menuBtn.addEventListener('click', () => {
      const isOpen = !menu.classList.contains('hidden');
      menu.classList.toggle('hidden');
      menuBtn.setAttribute('aria-expanded', String(!isOpen));
      menuBtn.setAttribute('aria-label',
        !isOpen
          ? (document.documentElement.lang === 'fr' ? 'Fermer le menu' : 'Close menu')
          : (document.documentElement.lang === 'fr' ? 'Ouvrir le menu' : 'Open menu')
      );
      // Prevent body scroll when menu is open
      document.body.style.overflow = !isOpen ? 'hidden' : '';
    });
  }

  // Dark mode toggles
  initDarkModeToggle();

  const mobileToggle = document.getElementById('dark-mode-toggle-mobile');
  if (mobileToggle) {
    mobileToggle.addEventListener('click', () => {
      document.getElementById('dark-mode-toggle')?.click();
    });
  }

  // Update dark mode icon
  function updateDarkModeIcons() {
    const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
    document.querySelectorAll('.dark-icon-sun').forEach(el => el.classList.toggle('hidden', isDark));
    document.querySelectorAll('.dark-icon-moon').forEach(el => el.classList.toggle('hidden', !isDark));
  }
  updateDarkModeIcons();
  const observer = new MutationObserver(updateDarkModeIcons);
  observer.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
</script>
