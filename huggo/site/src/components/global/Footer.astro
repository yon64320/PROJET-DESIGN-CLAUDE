---
import { getLocalePath } from '../../utils/i18n';

interface Props {
  locale: 'fr' | 'en';
}

const { locale } = Astro.props;

const contactEmail = import.meta.env.CONTACT_EMAIL || 'contact@huggo.ai';
const contactPhone = import.meta.env.CONTACT_PHONE || '+33 X XX XX XX XX';
const whatsappNumber = import.meta.env.WHATSAPP_NUMBER || '';

const navPages = locale === 'fr'
  ? [
      { label: 'Accueil', href: getLocalePath(locale) },
      { label: 'Retail', href: getLocalePath(locale, 'retail') },
      { label: 'Franchise', href: getLocalePath(locale, 'franchise') },
      { label: 'Collectivity', href: getLocalePath(locale, 'collectivity') },
    ]
  : [
      { label: 'Home', href: getLocalePath(locale) },
      { label: 'Retail', href: getLocalePath(locale, 'retail') },
      { label: 'Franchise', href: getLocalePath(locale, 'franchise') },
      { label: 'Collectivity', href: getLocalePath(locale, 'collectivity') },
    ];

const navOffres = locale === 'fr'
  ? [
      { label: 'Comment ça marche', href: getLocalePath(locale, 'how-it-works') },
      { label: 'Tarifs', href: getLocalePath(locale, 'pricing') },
    ]
  : [
      { label: 'How it works', href: getLocalePath(locale, 'how-it-works') },
      { label: 'Pricing', href: getLocalePath(locale, 'pricing') },
    ];

const navAbout = locale === 'fr'
  ? [
      { label: 'À propos', href: getLocalePath(locale, 'about') },
      { label: 'Contact', href: getLocalePath(locale, 'contact') },
    ]
  : [
      { label: 'About', href: getLocalePath(locale, 'about') },
      { label: 'Contact', href: getLocalePath(locale, 'contact') },
    ];

const atidgoMention = locale === 'fr' ? 'HUGGO, filiale d\'Atidgo' : 'HUGGO, a subsidiary of Atidgo';
const copyright = locale === 'fr'
  ? '© 2026 HUGGO. Tous droits réservés.'
  : '© 2026 HUGGO. All rights reserved.';
const legalLabel = locale === 'fr' ? 'Mentions légales' : 'Legal notice';
const privacyLabel = locale === 'fr' ? 'Politique de confidentialité' : 'Privacy policy';
---

<footer class="relative overflow-hidden" style="background-color: var(--color-surface-brand);">
  <!-- Decorative top gradient -->
  <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-white/20 to-transparent"></div>

  <div class="container py-16 lg:py-20">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-8">
      <!-- Column 1: Logo + Atidgo -->
      <div class="lg:col-span-1">
        <a href={getLocalePath(locale)} class="inline-block mb-4 group">
          <span class="text-3xl font-bold font-display tracking-tight text-white transition-transform duration-150 group-hover:scale-105 inline-block">huggo</span>
        </a>
        <p class="text-sm text-white/60 mb-6">{atidgoMention}</p>
        <div class="flex items-center gap-3">
          {whatsappNumber && (
            <a
              href={`https://wa.me/${whatsappNumber}`}
              target="_blank"
              rel="noopener noreferrer"
              class="w-10 h-10 rounded-full bg-white/10 hover:bg-white/20 flex items-center justify-center text-white transition-all duration-150"
              aria-label="WhatsApp"
            >
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
              </svg>
            </a>
          )}
        </div>
      </div>

      <!-- Column 2: Navigation -->
      <div>
        <h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-5">{locale === 'fr' ? 'Navigation' : 'Navigation'}</h3>
        <ul class="space-y-3">
          {navPages.map((page) => (
            <li>
              <a href={page.href} class="text-[0.9375rem] text-white/70 hover:text-white transition-colors duration-150">
                {page.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Column 3: Offres -->
      <div>
        <h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-5">{locale === 'fr' ? 'Offres' : 'Offers'}</h3>
        <ul class="space-y-3">
          {navOffres.map((page) => (
            <li>
              <a href={page.href} class="text-[0.9375rem] text-white/70 hover:text-white transition-colors duration-150">
                {page.label}
              </a>
            </li>
          ))}
        </ul>
        <h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-5 mt-8">{locale === 'fr' ? 'À propos' : 'About'}</h3>
        <ul class="space-y-3">
          {navAbout.map((page) => (
            <li>
              <a href={page.href} class="text-[0.9375rem] text-white/70 hover:text-white transition-colors duration-150">
                {page.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Column 4: Contact -->
      <div>
        <h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-5">Contact</h3>
        <ul class="space-y-3">
          <li>
            <a href={`mailto:${contactEmail}`} class="text-[0.9375rem] text-white/70 hover:text-white transition-colors duration-150 flex items-center gap-2">
              <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
              </svg>
              {contactEmail}
            </a>
          </li>
          <li>
            <a href={`tel:${contactPhone.replace(/\s/g, '')}`} class="text-[0.9375rem] text-white/70 hover:text-white transition-colors duration-150 flex items-center gap-2">
              <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
              </svg>
              {contactPhone}
            </a>
          </li>
        </ul>

        <!-- Legal links -->
        <div class="mt-8">
          <h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-5">{locale === 'fr' ? 'Légal' : 'Legal'}</h3>
          <ul class="space-y-3">
            <li>
              <a href={getLocalePath(locale, 'legal')} class="text-[0.9375rem] text-white/70 hover:text-white transition-colors duration-150">
                {legalLabel}
              </a>
            </li>
            <li>
              <a href={getLocalePath(locale, 'privacy')} class="text-[0.9375rem] text-white/70 hover:text-white transition-colors duration-150">
                {privacyLabel}
              </a>
            </li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-16 pt-8 border-t border-white/10 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-xs text-white/40">{copyright}</p>
      <a href={getLocalePath(locale)} class="text-lg font-bold font-display tracking-tight text-white/30 hover:text-white/50 transition-colors duration-150">huggo</a>
    </div>
  </div>
</footer>
