---
import PageLayout from '../../layouts/PageLayout.astro';
import HeroHome from '../../components/sections/HeroHome.astro';
import MetricsSection from '../../components/sections/MetricsSection.astro';
import LogoBar from '../../components/sections/LogoBar.astro';
import BenefitsGrid from '../../components/sections/BenefitsGrid.astro';
import VerticalsCards from '../../components/sections/VerticalsCards.astro';
import StepsSection from '../../components/sections/StepsSection.astro';
import FaqSection from '../../components/sections/FaqSection.astro';
import PreFooterCTA from '../../components/global/PreFooterCTA.astro';
import { getLocalePath } from '../../utils/i18n';

const locale = 'fr';

const metrics = [
  { value: '15', suffix: 'M', label: 'de commandes traitées' },
  { value: '15', prefix: '+', suffix: ' à +30%', label: 'de panier moyen vs app mobile' },
  { value: '60', suffix: '%', label: 'de clientèle digitalisée en 3 mois' },
  { value: '0', suffix: '%', label: 'de commission sur vos ventes' },
];

const benefits = [
  {
    heading: 'Gardez 100% de vos marges.',
    body: 'WhatsApp est un canal direct entre vous et vos clients. Pas de plateforme intermédiaire, pas de commission. Vos ventes vous appartiennent.',
    proof: 'Preuve : 0% de commission vs 20-30% sur les plateformes de livraison.',
  },
  {
    heading: 'Un vendeur qui ne dort jamais.',
    body: 'Votre assistant prend les commandes, recommande vos produits et relance les paniers abandonnés. Même à 23h, même le dimanche.',
    proof: 'Preuve : 15M de commandes traitées depuis mars 2025.',
  },
  {
    heading: 'Photo de votre carte, et c\'est parti.',
    body: 'Pas de développeur, pas de formation, pas de matériel. Prenez votre carte en photo ou synchronisez votre caisse : HUGGO crée votre assistant automatiquement.',
    proof: 'Preuve : 0 à 30% de clientèle digitalisée en 1 mois.',
  },
  {
    heading: 'WhatsApp, borne, caisse, site : un seul panier.',
    body: 'Votre client commence sa commande sur WhatsApp, la modifie en boutique, paie comme il veut. Tout est synchronisé en temps réel avec votre caisse.',
    proof: 'Preuve : connecté aux principaux systèmes de caisse via HubRise et Orisha Distribution.',
  },
];

const verticals = [
  {
    heading: 'Commerçants',
    body: 'Boulangerie, restaurant, traiteur, épicerie, caviste, bar, déco, habillement — votre assistant IA prend les commandes et fidélise vos clients réguliers.',
    cta: 'Découvrir l\'offre Retail',
    href: getLocalePath(locale, 'retail'),
  },
  {
    heading: 'Réseaux & Franchises',
    body: 'Un assistant IA par point de vente, une vision réseau consolidée. Déployez HUGGO sur 50, 200 ou 500 points de vente simultanément.',
    cta: 'Découvrir l\'offre Franchise',
    href: getLocalePath(locale, 'franchise'),
  },
  {
    heading: 'Collectivités & Circuit court',
    body: 'Producteurs locaux, commerces itinérants, communes sans commerce de proximité. HUGGO crée un canal de vente directe par WhatsApp, sans infrastructure.',
    cta: 'Découvrir l\'offre Collectivity',
    href: getLocalePath(locale, 'collectivity'),
  },
];

const steps = [
  { number: 1, heading: 'Trouvez votre commerce', body: 'HUGGO localise votre établissement sur Google Business.' },
  { number: 2, heading: 'Importez vos produits', body: 'Photo de votre carte ou synchronisation directe depuis votre caisse.' },
  { number: 3, heading: 'Votre assistant est créé', body: 'L\'IA configure un assistant WhatsApp personnalisé pour votre commerce.' },
  { number: 4, heading: 'Vos clients commandent', body: 'Votre numéro est publié sur Google Business. Les commandes arrivent.' },
];

const faqItems = [
  {
    question: 'Mes clients ne sont pas technophiles, ils n\'utiliseront jamais ça.',
    answer: 'Vos clients utilisent déjà WhatsApp — 95% des smartphones en France l\'ont installé. Ils n\'ont rien à télécharger, rien à apprendre. Ils envoient un message, comme ils le font 50 fois par jour. Résultat : 60% de la clientèle digitalisée en 3 mois, y compris chez des commerçants dont les clients n\'avaient jamais commandé en ligne.',
  },
  {
    question: 'WhatsApp, c\'est personnel. Pas pour commander.',
    answer: 'WhatsApp Business est aujourd\'hui le canal commercial le plus utilisé au monde. Vos clients préfèrent envoyer un message plutôt que téléphoner ou faire la queue. Les chiffres le confirment : 15 millions de commandes traitées via HUGGO depuis mars 2025.',
  },
  {
    question: 'C\'est cher, j\'ai déjà un site internet.',
    answer: 'Un site internet ne prend pas de commandes automatiquement, ne recommande pas de produits, ne relance pas les paniers abandonnés. HUGGO le fait 24h/24 sans embaucher. Et contrairement aux plateformes de livraison, zéro commission sur vos ventes. Résultat : +15 à +30% de panier moyen.',
  },
  {
    question: 'Je ne suis pas informaticien, c\'est trop compliqué.',
    answer: 'L\'installation se fait en quelques minutes. Prenez votre carte en photo — l\'IA s\'occupe du reste. Pas de matériel, pas de formation, pas de développeur. Votre assistant est opérationnel le jour même.',
  },
];

const schemaOrg = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'HUGGO',
  url: (import.meta.env.SITE_URL || 'https://huggo.ai') + '/fr/',
  description: 'Transformez WhatsApp en canal de vente pour votre commerce. Assistant IA 24/7, 0% commission, opérationnel en quelques minutes.',
  potentialAction: {
    '@type': 'SearchAction',
    target: (import.meta.env.SITE_URL || 'https://huggo.ai') + '/fr/?q={search_term_string}',
    'query-input': 'required name=search_term_string',
  },
};
---

<PageLayout
  title="HUGGO — Commande WhatsApp commerçants | 0% commission"
  description="Transformez WhatsApp en canal de vente pour votre commerce. Assistant IA 24/7, 0% commission, opérationnel en quelques minutes. Demandez une démo."
  locale={locale}
  alternateUrl="/en/"
  schemaOrg={schemaOrg}
>
  <!-- S1: Hero -->
  <HeroHome locale={locale} />

  <!-- S2: Chiffres clés -->
  <MetricsSection heading="Les chiffres parlent." metrics={metrics} />

  <!-- S3: Logo bar partenaires -->
  <LogoBar label="Compatible avec vos outils" />

  <!-- S4: Bénéfices clés -->
  <BenefitsGrid heading="Ce que HUGGO change pour votre commerce." benefits={benefits} />

  <!-- S5: Verticales -->
  <VerticalsCards locale={locale} heading="HUGGO s'adapte à votre activité." cards={verticals} />

  <!-- S6: Comment ça marche (résumé) -->
  <StepsSection
    heading="Opérationnel en 4 étapes."
    steps={steps}
    cta="Voir le fonctionnement détaillé →"
    ctaHref={getLocalePath(locale, 'how-it-works')}
  />

  <!-- S7: Social proof -->
  <section class="py-20 lg:py-24" style="background-color: var(--color-surface-secondary);" aria-label="Social proof">
    <div class="container">
      <!-- Testimonial placeholder -->
      <div class="max-w-2xl mx-auto text-center mb-16 animate">
        <div class="bg-[var(--color-surface-elevated)] border rounded-xl p-10 shadow-[var(--shadow-sm)]" style="border-color: var(--color-border-default);">
          <svg class="w-10 h-10 mx-auto mb-4 opacity-20" style="color: var(--color-text-secondary);" fill="currentColor" viewBox="0 0 24 24">
            <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151C7.563 6.068 6 8.789 6 11h4v10H0z" />
          </svg>
          <p class="text-lg italic mb-4" style="color: var(--color-text-secondary);">[Emplacement réservé pour témoignage commerçant]</p>
          <p class="text-sm" style="color: var(--color-text-secondary);">Photo + citation + nom/métier/ville</p>
        </div>
      </div>

      <!-- Partners tech -->
      <div class="text-center">
        <h3 class="font-display font-semibold text-xl mb-8 animate" style="color: var(--color-text-primary);">Construit avec les meilleurs.</h3>
        <div class="flex flex-wrap items-center justify-center gap-8 lg:gap-12 animate">
          {['Google Cloud Platform', 'Orisha Distribution', 'Centrale Paris/France', 'Contodeo'].map((partner) => (
            <div class="px-6 py-3 rounded-xl border" style="border-color: var(--color-border-default); background-color: var(--color-surface-elevated);">
              <span class="text-sm font-semibold" style="color: var(--color-text-secondary);">{partner}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- S8: Mascotte HUGGO -->
  <section class="py-20 lg:py-24" style="background-color: var(--color-surface-primary);" aria-label="Mascotte">
    <div class="container">
      <div class="flex flex-col md:flex-row items-center gap-10 max-w-3xl mx-auto animate">
        <div class="w-36 h-36 flex-shrink-0 rounded-full overflow-hidden shadow-lg ring-4 ring-white/50">
          <img
            src="/images/mascotte.jpeg"
            alt="Mascotte HUGGO"
            width="400"
            height="400"
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
        <div>
          <p class="text-lg leading-relaxed mb-5" style="color: var(--color-text-primary);">Une question ? Écrivez-nous directement sur WhatsApp. On vous répond comme on aime : vite et bien.</p>
          <a
            href={`https://wa.me/${import.meta.env.WHATSAPP_NUMBER || ''}`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-6 h-[46px] rounded-[20px] font-semibold text-white transition-all duration-150 hover:shadow-lg active:scale-[0.97] group"
            style="background-color: #25D366;"
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
            </svg>
            Discuter sur WhatsApp
            <svg class="w-4 h-4 transition-transform duration-150 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- S9: FAQ -->
  <FaqSection items={faqItems} />

  <!-- S10: Pré-footer CTA -->
  <PreFooterCTA
    locale={locale}
    heading="Prêt à reprendre le contrôle de vos ventes ?"
    subtext="15 minutes de démo suffisent pour voir HUGGO en action sur votre commerce."
    primaryCta="Demander une démo"
    secondaryCta="Nous contacter"
  />
</PageLayout>

<script>
  import { initGSAP, createFadeUp, createCounter, createStaggeredFadeUp } from '../../utils/gsap-init';
  import { initLenis } from '../../utils/lenis-init';

  async function init() {
    const result = await initGSAP();
    if (!result) return;

    const { gsap, ScrollTrigger } = result;

    // Counter animations
    const counters = document.querySelectorAll('.counter');
    if (counters.length > 0) {
      createCounter(gsap, ScrollTrigger, counters);
    }

    // Staggered benefits
    createStaggeredFadeUp(gsap, ScrollTrigger, '#benefits-grid', '.card-lift');

    // Staggered verticals
    createStaggeredFadeUp(gsap, ScrollTrigger, '#verticals-grid', 'a');

    // General fade-ups
    document.querySelectorAll('.animate').forEach((el) => {
      createFadeUp(gsap, ScrollTrigger, el);
    });

    // Init smooth scroll
    await initLenis();
  }

  init();
</script>
