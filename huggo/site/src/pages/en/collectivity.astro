---
import PageLayout from '../../layouts/PageLayout.astro';
import HeroPage from '../../components/sections/HeroPage.astro';
import MetricsSection from '../../components/sections/MetricsSection.astro';
import FaqSection from '../../components/sections/FaqSection.astro';
import PreFooterCTA from '../../components/global/PreFooterCTA.astro';
import { getLocalePath } from '../../utils/i18n';
const locale = 'en';
---
<PageLayout title="HUGGO Collectivity — Local Commerce via WhatsApp" description="62% of French municipalities have no shops. HUGGO connects producers and consumers via WhatsApp. Short supply chain, anti-waste." locale={locale} alternateUrl="/fr/collectivity">
  <HeroPage locale={locale} h1="Local commerce, even where there are no shops left." subtitle="HUGGO connects local producers and consumers via WhatsApp. No commercial space, no e-commerce site, no infrastructure. Just a message to order." ctaPrimary="Contact us" microText="Local authority or producer project — let's talk" />
  <MetricsSection heading="Rural France is losing its shops." metrics={[{ value: '400000', suffix: '+', label: 'farms in France' },{ value: '62', suffix: '%', label: 'of municipalities have no access to any shop' },{ value: '6', suffix: 'M', label: 'French people live more than 7 minutes from a food store' },{ value: '10000', label: 'mobile vendor trucks serve the country' }]} />
  <section class="py-20 lg:py-24" style="background-color: var(--color-surface-primary);" aria-label="Use cases"><div class="container max-w-4xl"><h2 class="font-display font-bold text-center mb-14 animate" style="font-size: clamp(1.625rem, 3.5vw, 2.25rem); color: var(--color-text-primary);">Three ways to bring back local commerce.</h2><div class="grid grid-cols-1 md:grid-cols-3 gap-6">{[{ heading: 'The producer selling direct.', body: 'Your market gardener, your cheesemaker, your beekeeper: they produce nearby, but selling is still complicated. With HUGGO, their customers order via WhatsApp and pick up at the farm or collection point.' },{ heading: 'The mobile vendor with pre-orders.', body: 'The bread truck comes on Tuesday. Customers pre-order on WhatsApp: no waste, no shortages. The vendor prepares exactly what was ordered.' },{ heading: 'The municipality running a "digital market."', body: 'Multiple local producers, one WhatsApp channel. Residents order; a weekly pickup point is organized. The municipality recreates commercial activity — without opening a store.' }].map((c) => (<div class="bg-[var(--color-surface-elevated)] border rounded-xl p-7 shadow-[var(--shadow-sm)] animate" style="border-color: var(--color-border-default);"><h3 class="font-display font-semibold text-lg mb-3" style="color: var(--color-text-primary);">{c.heading}</h3><p class="text-[0.9375rem] leading-relaxed" style="color: var(--color-text-secondary);">{c.body}</p></div>))}</div></div></section>
  <section class="py-20 lg:py-24" style="background-color: var(--color-surface-secondary);" aria-label="Benefits"><div class="container max-w-3xl"><h2 class="font-display font-bold text-center mb-14 animate" style="font-size: clamp(1.625rem, 3.5vw, 2.25rem); color: var(--color-text-primary);">Why WhatsApp is the right channel for rural areas.</h2><div class="space-y-6">{[{ heading: 'No infrastructure needed.', body: 'No commercial space, no e-commerce site, no dedicated payment terminal. A smartphone and WhatsApp are enough.' },{ heading: 'A channel everyone knows.', body: '95% of smartphones have WhatsApp. Nothing to download, no account to create. Accessible to non-tech-savvy users, elderly people, and passing tourists.', proof: 'Proof: 60% digitization in 3 months, among historically non-tech-savvy customers.' },{ heading: 'Direct producer-to-consumer link.', body: 'The producer sells, the consumer buys. No middleman, no commission, no platform. The supply chain is as short as it gets.' }].map((b) => (<div class="bg-[var(--color-surface-elevated)] border rounded-xl p-8 shadow-[var(--shadow-sm)] animate" style="border-color: var(--color-border-default);"><h3 class="font-display font-semibold text-lg mb-3" style="color: var(--color-text-primary);">{b.heading}</h3><p class="text-[0.9375rem] leading-relaxed" style="color: var(--color-text-secondary);">{b.body}</p>{b.proof && <p class="text-sm italic mt-3 flex items-center gap-2" style="color: var(--color-accent-action);"><svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>{b.proof}</p>}</div>))}</div></div></section>
  <section class="py-20 lg:py-24" style="background-color: var(--color-surface-primary);" aria-label="RSE Impact"><div class="container max-w-4xl"><h2 class="font-display font-bold text-center mb-14 animate" style="font-size: clamp(1.625rem, 3.5vw, 2.25rem); color: var(--color-text-primary);">Real impact, not intentions.</h2><div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">{[{ title: 'Anti-waste', desc: 'Pre-orders let the producer prepare only what\'s sold. Less waste, less surplus, less unnecessary transport.' },{ title: 'Digital inclusion', desc: 'HUGGO runs on WhatsApp — an app 95% of French people already have. No learning curve, no extra account.' },{ title: 'Strengthened local commerce', desc: 'Every order through HUGGO goes directly to the merchant. No middleman platform, no commission. Revenue stays local.' },{ title: 'Short supply chain', desc: 'From producer to consumer, no unnecessary steps. The distance from field to plate is measured in kilometers, not warehouses.' },{ title: 'Accessibility', desc: 'Order without traveling, without queuing, without time constraints. For people with reduced mobility, elderly people, families in remote areas.' }].map((i) => (<div class="bg-[var(--color-surface-elevated)] border rounded-xl p-6 shadow-[var(--shadow-sm)] animate" style="border-color: var(--color-border-default);"><h3 class="font-display font-semibold mb-2" style="color: var(--color-brand-primary);">{i.title}</h3><p class="text-sm leading-relaxed" style="color: var(--color-text-secondary);">{i.desc}</p></div>))}</div></div></section>
  <FaqSection items={[{ question: 'The rural population isn\'t connected.', answer: 'WhatsApp is installed on 95% of French smartphones. Nothing to download. HUGGO has already digitized 60% of the customer base of merchants whose clients had never ordered online — proof that the digital divide is a perceived barrier, not a real one.' },{ question: 'We don\'t have a tech budget.', answer: 'No infrastructure needed: no premises, no hardware, no developer. An affordable monthly subscription, no commission on sales.' },{ question: 'Local producers already have their sales channels.', answer: 'HUGGO complements — it doesn\'t replace. Pre-orders reduce waste, expand the customer base beyond the weekly market, and enable sales on days the market is closed.' }]} />
  <PreFooterCTA locale={locale} heading="Let's build a local commerce channel together." subtext="Whether you're a producer, local authority, or mobile vendor — let's talk about what HUGGO can do for your area." primaryCta="Contact us" secondaryCta="Request a demo" />
</PageLayout>
<script>import { initGSAP, createFadeUp, createCounter } from '../../utils/gsap-init';import { initLenis } from '../../utils/lenis-init';async function init() { const result = await initGSAP(); if (!result) return; const { gsap, ScrollTrigger } = result; const counters = document.querySelectorAll('.counter'); if (counters.length > 0) createCounter(gsap, ScrollTrigger, counters); document.querySelectorAll('.animate').forEach((el) => createFadeUp(gsap, ScrollTrigger, el)); await initLenis(); }init();</script>
