---
import PageLayout from '../../layouts/PageLayout.astro';
import HeroPage from '../../components/sections/HeroPage.astro';
import MetricsSection from '../../components/sections/MetricsSection.astro';
import FaqSection from '../../components/sections/FaqSection.astro';
import PreFooterCTA from '../../components/global/PreFooterCTA.astro';
import { getLocalePath } from '../../utils/i18n';
const locale = 'en';
---
<PageLayout title="HUGGO Franchise — WhatsApp Deployment for Networks" description="Deploy HUGGO across your franchise network. One AI assistant per location, consolidated analytics, centralized management. Contact us." locale={locale} alternateUrl="/fr/franchise">
  <HeroPage locale={locale} h1="Deploy HUGGO across your entire network. One AI assistant per location." subtitle="Each franchisee gets their own WhatsApp assistant, personalized to their store. You maintain full network oversight: consolidated analytics, centralized management, phased or simultaneous rollout." ctaPrimary="Contact us" microText="Network pricing on request" />
  <section class="py-20 lg:py-24" style="background-color: var(--color-surface-secondary);" aria-label="Issues"><div class="container max-w-4xl"><h2 class="font-display font-bold text-center mb-14 animate" style="font-size: clamp(1.625rem, 3.5vw, 2.25rem); color: var(--color-text-primary);">Managing a franchise network also means managing its inconsistencies.</h2><div class="grid grid-cols-1 md:grid-cols-3 gap-6">{[{ heading: 'Uneven rollout.', body: 'Each location adopts its own tools. The result: no unified view, no client standard, no comparable data.' },{ heading: 'Fragmented analytics.', body: 'Data is scattered across POS systems, platforms, and spreadsheets. Comparing 200 locations on a single dashboard? Not possible.' },{ heading: 'Inconsistent customer experience.', body: 'A customer orders easily at one location, struggles at another. Your brand loses coherence.' }].map((i) => (<div class="bg-[var(--color-surface-elevated)] border rounded-xl p-7 shadow-[var(--shadow-sm)] animate" style="border-color: var(--color-border-default);"><h3 class="font-display font-semibold text-lg mb-3" style="color: var(--color-text-primary);">{i.heading}</h3><p class="text-[0.9375rem] leading-relaxed" style="color: var(--color-text-secondary);">{i.body}</p></div>))}</div></div></section>
  <section class="py-20 lg:py-24" style="background-color: var(--color-surface-primary);" aria-label="Solutions"><div class="container max-w-4xl"><h2 class="font-display font-bold text-center mb-14 animate" style="font-size: clamp(1.625rem, 3.5vw, 2.25rem); color: var(--color-text-primary);">One network, one platform, one standard.</h2><div class="space-y-6">{[{ heading: 'Simultaneous rollout, location by location.', body: 'Activate HUGGO across 50, 200, or 500 locations. Each franchisee gets their AI assistant in minutes — local menu, local hours, local promotions.', proof: 'Proof: 3 CHR distributors already deploy HUGGO nationwide.' },{ heading: 'Consolidated network analytics.', body: 'A single dashboard: revenue per location, average basket, conversion rate, campaign performance. Network view + individual view.' },{ heading: 'Local personalization under central control.', body: 'Each location has its own menu, schedule, and promotions. Headquarters maintains control over branding, standards, and reporting.' }].map((a) => (<div class="bg-[var(--color-surface-elevated)] border rounded-xl p-8 shadow-[var(--shadow-sm)] animate" style="border-color: var(--color-border-default);"><h3 class="font-display font-semibold text-lg mb-3" style="color: var(--color-text-primary);">{a.heading}</h3><p class="text-[0.9375rem] leading-relaxed" style="color: var(--color-text-secondary);">{a.body}</p>{a.proof && <p class="text-sm italic mt-3 flex items-center gap-2" style="color: var(--color-accent-action);"><svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>{a.proof}</p>}</div>))}</div></div></section>
  <section class="py-20 lg:py-24" style="background-color: var(--color-surface-secondary);" aria-label="Features"><div class="container max-w-3xl"><h2 class="font-display font-bold text-center mb-14 animate" style="font-size: clamp(1.625rem, 3.5vw, 2.25rem); color: var(--color-text-primary);">Built for networks.</h2><div class="space-y-4">{[{ label: 'Batch onboarding', desc: 'activate dozens of locations in a single operation' },{ label: 'Centralized management', desc: 'configuration, updates, and promotions from headquarters' },{ label: 'Consolidated reporting', desc: 'revenue, average basket, conversion rate — by network and by location' },{ label: 'Local personalization', desc: 'menu, hours, pricing, and promotions tailored to each franchisee' },{ label: 'Multi-language', desc: 'each assistant adapts to the local customer language' }].map((f) => (<div class="flex items-start gap-4 bg-[var(--color-surface-elevated)] border rounded-xl p-5 shadow-[var(--shadow-sm)] animate" style="border-color: var(--color-border-default);"><svg class="w-5 h-5 flex-shrink-0 mt-0.5" style="color: var(--color-feedback-success);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg><p class="text-[0.9375rem]"><strong class="font-semibold" style="color: var(--color-text-primary);">{f.label}</strong> <span style="color: var(--color-text-secondary);">— {f.desc}</span></p></div>))}</div></div></section>
  <MetricsSection heading="Results at scale." metrics={[{ value: '15', suffix: 'M', label: 'orders processed through HUGGO' },{ value: '3', label: 'CHR distributors deploying HUGGO nationwide' },{ value: '60', suffix: '%', label: 'customer base digitized within 3 months per location' }]} />
  <FaqSection items={[{ question: 'How do we deploy across 200 locations?', answer: 'HUGGO offers batch onboarding. Each location is activated with its own menu, hours, and local settings. Rollout can be phased (by zone) or simultaneous. Our team manages the launch with you.' },{ question: 'Each franchisee has their own menu and hours.', answer: 'Each location gets its own personalized AI assistant — menu, hours, pricing, promotions. Headquarters retains control over network standards and consolidated reporting.' },{ question: 'What network reporting do you offer?', answer: 'A single dashboard with network-level and per-location views: revenue, average basket, conversion rate, order hours, campaign performance.' },{ question: 'Is pricing adapted to volume?', answer: 'Pricing is volume-based and decreases with the number of locations. Contact our sales team for a network quote.' }]} />
  <PreFooterCTA locale={locale} heading="Let's talk about your rollout." subtext="Our sales team will present HUGGO and build a proposal tailored to the size of your network." primaryCta="Contact us" secondaryCta="Request a demo" />
</PageLayout>
<script>import { initGSAP, createFadeUp, createCounter } from '../../utils/gsap-init';import { initLenis } from '../../utils/lenis-init';async function init() { const result = await initGSAP(); if (!result) return; const { gsap, ScrollTrigger } = result; const counters = document.querySelectorAll('.counter'); if (counters.length > 0) createCounter(gsap, ScrollTrigger, counters); document.querySelectorAll('.animate').forEach((el) => createFadeUp(gsap, ScrollTrigger, el)); await initLenis(); }init();</script>
