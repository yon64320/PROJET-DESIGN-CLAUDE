---
import PageLayout from '../../layouts/PageLayout.astro';
import HeroPage from '../../components/sections/HeroPage.astro';
import PricingTiers from '../../components/sections/PricingTiers.astro';
import FaqSection from '../../components/sections/FaqSection.astro';
import PreFooterCTA from '../../components/global/PreFooterCTA.astro';
import { getLocalePath } from '../../utils/i18n';
const locale = 'en';
---
<PageLayout title="HUGGO Pricing — Feature Tiers | 0% Commission" description="Discover HUGGO tiers: Essentials, Smart, Marketing, Analytics. Zero commission on sales. Request a personalized quote within 24h." locale={locale} alternateUrl="/fr/pricing">
  <HeroPage locale={locale} h1="A tier for every business." subtitle="Pricing tailored to your activity and volume. Zero commission on your sales, whichever tier you choose." ctaPrimary="Request a quote" microText="Personalized quote within 24h" />
  <PricingTiers locale={locale} heading="Four tiers, one promise: zero commission." tiers={[
    { name: 'Essentials', description: 'Everything you need to sell on WhatsApp.', features: ['Conversational ordering via WhatsApp', 'Integrated basket and payment (Contodeo)', 'QR code Click & Collect', 'Real-time order tracking', 'Order history', 'Automatic customer profiles'], ctaLabel: 'Request a quote' },
    { name: 'Smart', description: 'The intelligence that makes the difference.', isPopular: true, features: ['Everything in Essentials, plus:', 'Product recommendations (upsell and cross-sell)', 'Customer memory: "The usual?" in one message', 'Promotional push (clearance, new items)', 'Automatic abandoned cart follow-up'], ctaLabel: 'Request a quote' },
    { name: 'Marketing', description: 'Anticipate demand. Target your customers.', features: ['Everything in Smart, plus:', 'AI-generated promotional banners', 'Predictive model: weather + local event crossover', 'Customer targeting by purchase behavior', 'Automatic Google review request'], ctaLabel: 'Request a quote' },
    { name: 'Analytics', description: 'The data to steer.', features: ['Detailed revenue by HUGGO channel', 'Average basket and conversion rate', 'Order hours (planning optimization)', 'Campaign performance', 'Product promotion recommendations'], ctaLabel: 'Request a quote', isAddon: true },
  ]} />
  <section class="py-20 lg:py-24" style="background-color: var(--color-surface-secondary);" aria-label="Included"><div class="container max-w-3xl"><h2 class="font-display font-bold text-center mb-14 animate" style="font-size: clamp(1.625rem, 3.5vw, 2.25rem); color: var(--color-text-primary);">No matter your tier, these fundamentals are included.</h2><div class="space-y-4">{[{ label: 'Zero commission', desc: 'on all your sales — flat monthly subscription' },{ label: 'POS sync', desc: 'HUGGO connects to your existing POS system' },{ label: 'Multi-method payment', desc: 'Apple Pay, Google Pay, Stripe, Contodeo' },{ label: 'Updates included', desc: 'your assistant evolves at no extra cost' }].map((i) => (<div class="flex items-start gap-4 bg-[var(--color-surface-elevated)] border rounded-xl p-5 shadow-[var(--shadow-sm)] animate" style="border-color: var(--color-border-default);"><svg class="w-5 h-5 flex-shrink-0 mt-0.5" style="color: var(--color-feedback-success);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg><p class="text-[0.9375rem]"><strong class="font-semibold" style="color: var(--color-text-primary);">{i.label}</strong> <span style="color: var(--color-text-secondary);">— {i.desc}</span></p></div>))}</div></div></section>
  <section class="py-20 lg:py-24" style="background-color: var(--color-surface-primary);" aria-label="ROI"><div class="container max-w-3xl"><h2 class="font-display font-bold text-center mb-14 animate" style="font-size: clamp(1.625rem, 3.5vw, 2.25rem); color: var(--color-text-primary);">ROI is visible from month one.</h2><div class="space-y-6">{[{ heading: '+15 to +30% average basket.', body: 'Your customers order more when friction disappears. Product recommendations, customer memory, cart follow-up: HUGGO increases the average ticket naturally.' },{ heading: '0% commission vs 20-30% on platforms.', body: 'On \u20AC5,000 monthly revenue through a delivery platform, you give back \u20AC1,000 to \u20AC1,500 in commissions. With HUGGO: zero.' },{ heading: 'Live the same day.', body: 'No weeks of setup, no developer to pay. Your WhatsApp assistant goes live in minutes.' }].map((i) => (<div class="bg-[var(--color-surface-elevated)] border rounded-xl p-8 shadow-[var(--shadow-sm)] animate" style="border-color: var(--color-border-default);"><h3 class="font-display font-semibold text-lg mb-3" style="color: var(--color-text-primary);">{i.heading}</h3><p class="text-[0.9375rem] leading-relaxed" style="color: var(--color-text-secondary);">{i.body}</p></div>))}</div></div></section>
  <section class="py-16 lg:py-20" style="background-color: var(--color-surface-secondary);" aria-label="Network"><div class="container max-w-2xl text-center"><div class="bg-[var(--color-surface-elevated)] border rounded-xl p-8 shadow-[var(--shadow-sm)] animate" style="border-color: var(--color-brand-primary);"><h3 class="font-display font-semibold text-xl mb-3" style="color: var(--color-text-primary);">Managing a network of 50+ locations?</h3><p class="text-[0.9375rem] leading-relaxed mb-6" style="color: var(--color-text-secondary);">Dedicated pricing, volume-based. A dedicated account manager to build your tailored proposal.</p><a href={getLocalePath(locale, 'contact')} class="inline-flex items-center gap-2 px-6 h-[46px] rounded-[20px] font-semibold text-[0.9375rem] active:scale-[0.97] transition-all duration-150 group border-2" style="border-color: var(--color-brand-primary); color: var(--color-brand-primary);">Contact us<svg class="w-4 h-4 transition-transform duration-150 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg></a></div></div></section>
  <FaqSection items={[{ question: 'Why aren\'t prices shown?', answer: 'Because pricing is adapted to your activity, volume, and vertical (retail, franchise, collectivity). We prefer offering you a fair quote rather than a generic price. Response within 24h.' },{ question: 'Are there commissions on sales?', answer: 'No. No commission, no percentage taken from your sales. The subscription is monthly and flat.' },{ question: 'Can I change tiers?', answer: 'Yes. You can upgrade at any time, with no service interruption.' },{ question: 'What does it cost for a network?', answer: 'Network pricing is volume-based and decreases with the number of locations. Contact our sales team for a tailored quote.' }]} />
  <PreFooterCTA locale={locale} heading="Get your quote within 24h." subtext="Tell us about your business — we'll send a tailored quote, no strings attached." primaryCta="Request a quote" secondaryCta="Request a demo" />
</PageLayout>
<script>import { initGSAP, createFadeUp, createStaggeredFadeUp } from '../../utils/gsap-init';import { initLenis } from '../../utils/lenis-init';async function init() { const result = await initGSAP(); if (!result) return; const { gsap, ScrollTrigger } = result; createStaggeredFadeUp(gsap, ScrollTrigger, '#pricing-grid', 'div[class*="card-lift"]'); document.querySelectorAll('.animate').forEach((el) => createFadeUp(gsap, ScrollTrigger, el)); await initLenis(); }init();</script>
