---
import PageLayout from '../../layouts/PageLayout.astro';
import HeroPage from '../../components/sections/HeroPage.astro';
import StepsSection from '../../components/sections/StepsSection.astro';
import MetricsSection from '../../components/sections/MetricsSection.astro';
import FaqSection from '../../components/sections/FaqSection.astro';
import PreFooterCTA from '../../components/global/PreFooterCTA.astro';
import { getLocalePath } from '../../utils/i18n';
const locale = 'en';
---
<PageLayout title="How It Works — HUGGO | Onboarding in 4 Steps" description="See how HUGGO works in 4 simple steps. From a photo of your menu to a live WhatsApp assistant, in minutes." locale={locale} alternateUrl="/fr/how-it-works">
  <HeroPage locale={locale} h1="From zero to live in minutes." subtitle="No app to install. No developer to hire. Four steps, and your WhatsApp assistant takes its first orders." ctaPrimary="Request a demo" microText="15 minutes to understand everything" />
  <StepsSection heading="Four steps. That's it." detailed={true} steps={[
    { number: 1, heading: 'Find your store.', body: 'HUGGO locates your business on Google Business. Your address, hours, photos — everything is pulled automatically.' },
    { number: 2, heading: 'Import your products.', body: 'Two options: take a photo of your menu — the AI reads it and builds your catalog. Or sync directly from your POS to keep the catalog always up to date.' },
    { number: 3, heading: 'Your assistant is built.', body: 'AI configures a personalized WhatsApp assistant for your store. It knows your products, prices, and hours. It\'s ready to serve your customers.' },
    { number: 4, heading: 'Your customers start ordering.', body: 'Your WhatsApp number goes live on Google Business. Your customers find you, scan your QR code, and order directly. Word of mouth does the rest.' },
  ]} />
  <section class="py-20 lg:py-24" style="background-color: var(--color-surface-secondary);" aria-label="Demo conversation"><div class="container max-w-2xl"><h2 class="font-display font-bold text-center mb-10 animate" style="font-size: clamp(1.625rem, 3.5vw, 2.25rem); color: var(--color-text-primary);">This is what your customers experience.</h2><div class="bg-[var(--color-surface-elevated)] border rounded-2xl p-6 shadow-[var(--shadow-md)] animate" style="border-color: var(--color-border-default);"><div class="space-y-4">{[{ from: 'client', text: 'Hi, I\'d like to order for lunch.' },{ from: 'huggo', text: 'Hello Marie! Your usual order? A country loaf and 2 croissants?' },{ from: 'client', text: 'Yes, and add an apple tart.' },{ from: 'huggo', text: 'Done. Total: \u20AC12.80. Pickup at 12:15. Pay now or in store?' },{ from: 'client', text: 'I\'ll pay now.' },{ from: 'huggo', text: 'Payment received. Your order will be ready at 12:15. See you soon!' }].map((msg) => (<div class={`flex ${msg.from === 'client' ? 'justify-end' : 'justify-start'}`}><div class={`max-w-[80%] px-4 py-3 rounded-2xl text-sm leading-relaxed ${msg.from === 'client' ? 'rounded-br-md' : 'rounded-bl-md'}`} style={msg.from === 'client' ? 'background-color: #DCF8C6; color: #1A1D1E;' : 'background-color: var(--color-surface-secondary); color: var(--color-text-primary);'}><p class="font-semibold text-xs mb-1 opacity-60">{msg.from === 'client' ? 'Customer' : 'HUGGO Assistant'}</p>{msg.text}</div></div>))}</div></div></div></section>
  <section class="py-20 lg:py-24" style="background-color: var(--color-surface-primary);" aria-label="Basket 360"><div class="container max-w-4xl text-center"><h2 class="font-display font-bold mb-6 animate" style="font-size: clamp(1.625rem, 3.5vw, 2.25rem); color: var(--color-text-primary);">One basket. Every channel.</h2><p class="text-lg leading-relaxed mb-10 animate max-w-2xl mx-auto" style="color: var(--color-text-secondary);">Your customer adds a product on WhatsApp. In store, they update their order on the kiosk or iPad. They pay at the counter. The basket is the same, everywhere, in real time.</p><div class="flex flex-wrap justify-center gap-3 mb-10 animate">{['WhatsApp', 'In-store kiosk', 'iPad', 'POS', 'Website', 'Payment'].map((c) => (<span class="px-5 py-2.5 rounded-xl text-sm font-semibold shadow-sm" style="background-color: var(--color-accent-subtle); color: var(--color-accent-action);">{c}</span>))}</div></div></section>
  <section class="py-20 lg:py-24" style="background-color: var(--color-surface-secondary);" aria-label="Video"><div class="container max-w-3xl text-center"><h2 class="font-display font-bold mb-8 animate" style="font-size: clamp(1.625rem, 3.5vw, 2.25rem); color: var(--color-text-primary);">See HUGGO in action.</h2><div class="aspect-video bg-[var(--color-surface-elevated)] border rounded-2xl flex items-center justify-center shadow-[var(--shadow-md)] animate" style="border-color: var(--color-border-default);"><div class="text-center p-8"><svg class="w-16 h-16 mx-auto mb-4 opacity-20" style="color: var(--color-text-secondary);" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg><p class="text-sm" style="color: var(--color-text-secondary);">[Video — to provide]</p></div></div></div></section>
  <MetricsSection heading="What HUGGO actually changes." metrics={[{ value: '60', suffix: '%', label: 'customer base digitized in 3 months' },{ value: '15', prefix: '+', suffix: ' to +30%', label: 'average basket vs mobile app' },{ value: '15', suffix: 'M', label: 'orders processed since March 2025' }]} />
  <FaqSection items={[{ question: 'Do I need a developer to set this up?', answer: 'No. Four steps, no technical skills. Photo of your menu, POS sync, and your assistant goes live. No developer needed.' },{ question: 'What if my POS isn\'t compatible?', answer: 'HUGGO connects to the major POS systems on the market via HubRise and Orisha Distribution. If your POS is listed on HubRise, connection is automatic.' },{ question: 'How will my customers know they can order on WhatsApp?', answer: 'HUGGO automatically publishes your number on Google Business. A QR code for in-store display is generated. Your regulars discover it with their first order and spread the word.' }]} />
  <PreFooterCTA locale={locale} heading="Convinced? Take the next step." subtext="Request your demo — 15 minutes to see HUGGO in action for your store." primaryCta="Request a demo" secondaryCta="See pricing" secondaryHref={getLocalePath(locale, 'pricing')} />
</PageLayout>
<script>import { initGSAP, createFadeUp, createCounter } from '../../utils/gsap-init';import { initLenis } from '../../utils/lenis-init';async function init() { const result = await initGSAP(); if (!result) return; const { gsap, ScrollTrigger } = result; const counters = document.querySelectorAll('.counter'); if (counters.length > 0) createCounter(gsap, ScrollTrigger, counters); document.querySelectorAll('.animate').forEach((el) => createFadeUp(gsap, ScrollTrigger, el)); await initLenis(); }init();</script>
